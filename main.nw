        SUBROUTINE
        ; The nav-view markers and the XOR shape blitter.
        ;
        ; Behavior:
        ;   DRAW_SHIP_NAV / DRAW_ACTOR_NAV set up a shape index and fall into
        ;   BLIT_SETUP -> BLIT_SHAPE_AT, which fetches the shape (self-modified
        ;   SHAPE_SMC pointer), pre-shifts it (SHAPE_PRESHIFT) and XOR-blits it
        ;   through the hi-res row tables, accumulating any collision in
        ;   ZP_BLIT_HIT.
        ;
