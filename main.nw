        JSR WIN_SAVE
        JSR WIN_TEXT
        LDA #$17
        STA MON_CV
        LDA #$0F
        STA MON_CH
        JSR KEY_WAIT
        PHA
        JSR WIN_RESTORE
        PLA
        RTS
