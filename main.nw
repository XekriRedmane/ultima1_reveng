@ %def FV_DRVMASK FV_TRACK FV_VECTOR

\texttt{FV\_WRITE\_BLOCK} is the MLI \texttt{WRITE\_BLOCK} call, used for every
block the directory writer commits.

<<gen fv write block>>=
        ORG $A286
FV_WRITE_BLOCK
        SUBROUTINE
        ; MLI WRITE_BLOCK wrapper.
        ;
        ; Behavior:
        ;   Issue a ProDOS MLI WRITE_BLOCK ($81) for the prepared paramblock,
        ;   incrementing the write counter (FV_WRCNT).
        ;
        ; Clobbers: A, X, Y
        INC FV_WRCNT
        JSR MLI
        STA ($90,X)
        LDX #$60
@ %def FV_WRITE_BLOCK

<<gen fv wr3>>=
        ORG $A290
FV_WR3
        HEX 03000000
FV_WRCNT
        HEX 0000
@ %def FV_WR3 FV_WRCNT

\texttt{FV\_INIT\_FIELDS} fills the standard ProDOS directory-header fields ---
storage type and name length, access bits, the \texttt{\$27}-byte entry length
and thirteen entries per block, the creation date from the ProDOS global page,
and the version bytes --- and the entry/block-threading helpers complete the
chain.

<<gen fv init dir>>=
        ORG $A296
FV_INIT_FIELDS
        SUBROUTINE
        ; Initialise the directory-header fields.
        ;
        ; Behavior:
        ;   FV_INIT_FIELDS fills in the standard ProDOS volume-directory header
        ;   (storage type/name length, access bits, entry length $27, entries
        ;   per block $0D, the creation date from PRODOS_DATE, ProDOS version);
        ;   FV_SET_ENTRY writes one field, FV_NEXT_BLOCK threads the forward/
        ;   backward block links.
        ;
        ; Clobbers: A, X, Y
        JSR FV_ZERO_BLK
        LDA #$02
        LDX #$04
        JSR FV_SET_ENTRY
        BCS .LA2BB
        LDA #$03
        LDX #$05
        JSR FV_SET_ENTRY
        BCS .LA2BB
        LDA #$04
        LDX #$00
FV_SET_ENTRY
        LDY #$00
        STA (ZP_A2L),Y
        LDY #$02
        TXA
        STA (ZP_A2L),Y
        JSR FV_WRITE_BLOCK
.LA2BB
        RTS
FV_NEXT_BLOCK
        LDA FV_BMPTR
        AND #$07
        STA FV_REMAIN
        LDA FV_BMPTR
        AND #$F8
        CLC
        LDX #$03
.LA2CC
        ROR FV_BMPTR+1
        ROR
        DEX
        BNE .LA2CC
        STA FV_BMPTR
        RTS
@ %def FV_INIT_FIELDS FV_SET_ENTRY FV_NEXT_BLOCK

<<gen fv remain>>=
