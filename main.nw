        LDA ACTOR_X,X
        STA ZP_CX
        LDA ACTOR_Y,X
        STA ZP_CY
        CLC
        LDA ACTOR_SHAPE,X
        BNE .L9DCA
        RTS
.L9DCA
        ADC ACTOR_HEAD,X
        STA BLIT_SHAPE
BLIT_SETUP
        LDA DRAW_MODE
        PHA
        LDA #$40
        STA DRAW_MODE
        JSR BLIT_SHAPE_AT
        PLA
        STA DRAW_MODE
        RTS
