        LDY READY_ARMOUR+1
        LDA XPORT_FRAME,Y
        CLC
        ADC HEAD_CUR
        ADC ROT_STEP
        STA BLIT_SHAPE
        LDA ZP_VX
        STA ZP_CX
        LDA ZP_VY
        STA ZP_CY
        JMP BLIT_SETUP
