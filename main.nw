; --- Copy-source spans inside this file (see the RORG chunks) ---
PAGE1_SRC       EQU $2223       ; page-one helpers, file location
PAGE1_END       EQU $2291
MLIB_SRC        EQU $2292       ; file library, file location
MLIB_END        EQU $2691
@ %def MON_CH MON_A1 MON_A2 MON_A4 RESET_VEC MON_SETTXT MON_TABV ROM_MACHID
@ %def MON_WAIT MON_PRBYTE MON_COUT MON_CROUT MON_MOVE MON_SETKBD MON_SETVID
@ %def SPEAKER SET_STDZP SET_ALTZP MLI GP_DEVNUM GP_BITMAP_B0 GP_BITMAP_B8
@ %def GP_MACHID GP_IBAKVER GP_IVERSION SYS_PATH SAVED_PATH MLIB_IOBUF
@ %def PAGE1_SRC PAGE1_END MLIB_SRC MLIB_END

\section{The system file header}

A ProDOS system program that supports startup files begins with a
[[JMP]], the two-byte signature [[$EE]]~[[$EE]], a buffer-length byte,
and a length-prefixed default pathname. A program selector (or another
system program chaining to this one) may overwrite the buffer with a
different startup file before launch; ProDOS itself leaves the default
in place. The buffer is 64 bytes; the space after it, up to the code,
includes the area at [[PREFIX_BUF]] used later to build a
zero-terminated volume prefix.

<<u1system header>>=
        ORG $2000
SYS_ENTRY
        JMP SYS_INIT
        DC.B $EE,$EE                    ; "supports startup file" signature
        DC.B $40                        ; startup path buffer length
STARTUP_PATH
        DC.B $08                        ; pathname length
        DC.B "U1.INTRO"                 ; default startup file
        DS.B 55,$00                     ; rest of the 64-byte path buffer
PREFIX_BUF
        DS.B 66,$00                     ; zero-terminated prefix is built here
@ %def SYS_ENTRY STARTUP_PATH PREFIX_BUF

\section{Initialization}

Standard system-program hygiene: record the interpreter version in the
global page, reset the stack, detach any 80-column firmware
(control-U through [[MON_COUT]]), restore keyboard/video/text, and
clear the screen. Then the page-one helpers
(section~\ref{sec:page-one-helpers}) are copied into place with the
monitor's block-move so they survive whatever the startup file loads
over this launcher.

<<u1system init>>=
        ORG $2088
SYS_INIT
        SUBROUTINE
        ; Launcher entry from ProDOS.
        ;
        ; Behavior:
        ;   Record interpreter version bytes, reset the stack, detach
        ;   the 80-column firmware, reset I/O hooks and text mode,
        ;   then copy the page-one helpers to PRINT_INLINE and fall
        ;   into the banner display.
        SEI
        LDA #$00
        STA GP_IVERSION
        LDA #$01
        STA GP_IBAKVER
        LDX #$FF                        ; reset the stack
        TXS
        LDA #$15                        ; ctrl-U: 80-column firmware off
        JSR MON_COUT
        JSR MON_SETKBD
        JSR MON_SETVID
        JSR MON_SETTXT
        JSR MON_HOME
        LDA #<PAGE1_SRC
        STA MON_A1
        LDA #>PAGE1_SRC
        STA MON_A1+1
        LDA #<PAGE1_END
        STA MON_A2
        LDA #>PAGE1_END
        STA MON_A2+1
        LDA #<PRINT_INLINE
        STA MON_A4
        LDA #>PRINT_INLINE
        STA MON_A4+1
        LDY #$00
        JSR MON_MOVE                    ; copy helpers to page one
@ %def SYS_INIT

\section{The title banner}

Five positioned strings on the 40-column text screen. Each
[[PRINT_INLINE]] call is followed by the high-ASCII text itself,
zero-terminated; the helper prints it and returns to the instruction
after the terminator. The title is over- and under-lined with rows of
underscores.

<<u1system banner>>=
        ORG $20C4
SYS_BANNER
        SUBROUTINE
        ; Print the title banner.
        ;
        ; Behavior:
        ;   Five PRINT_INLINE calls at fixed rows/columns: over- and
        ;   under-lined "Ultima I", the subtitle, and the copyright.
        ;   Falls into SYS_INSTALL.
        LDA #$07
        JSR MON_TABV
        LDA #$10
        STA MON_CH
        JSR PRINT_INLINE
        HEX df df df df df df df df    ; "________"
        HEX 00
        LDA #$09
        JSR MON_TABV
        LDA #$10
        STA MON_CH
        JSR PRINT_INLINE
        HEX d5 ec f4 e9 ed e1 a0 c9    ; "Ultima I"
        HEX 00
        LDA #$0A
        JSR MON_TABV
        LDA #$10
        STA MON_CH
        JSR PRINT_INLINE
        HEX df df df df df df df df    ; "________"
        HEX 00
        LDA #$0D
        JSR MON_TABV
        LDA #$07
        STA MON_CH
        JSR PRINT_INLINE
        HEX d4 e8 e5 a0 c6 e9 f2 f3    ; "The Firs"
        HEX f4 a0 c1 e7 e5 a0 ef e6    ; "t Age of"
        HEX a0 c4 e1 f2 eb ee e5 f3    ; " Darknes"
        HEX f3 00                      ; "s"
        LDA #$17
        JSR MON_TABV
        LDA #$01
        STA MON_CH
