NPC_DIST
        SUBROUTINE
        ; Euclidean distance from NPC slot X to the player.
        ;
        ; Inputs:
        ;   X        — NPC slot; NPC_X[X]/NPC_Y[X] vs the player ZP_X/ZP_Y.
        ;
        ; Behavior:
        ;   Form dx^2 + dy^2 by repeated addition into DIST_LO, then
        ;   ISQRT it -- the same integer square root the dungeon uses
        ;   for monster homing.  Returns the rounded distance in A
        ;   (or $FF if either coordinate is off-map).
        STX DIST_IDX
        LDA NPC_X,X
        CMP #$FF
        BEQ .LA478
        LDA ZP_X
        CMP #$FF
        BEQ .LA478
        SEC
        SBC NPC_X,X
        BCS .LA415
        STA ABS_TMP
        SEC
        LDA #$00
        SBC ABS_TMP
.LA415
        LDY #$00
        STY DIST_LO
        STY DIST_LO+1
        TAY
        TAX
        INX
.LA420
        DEX
        BEQ .LA432
        TYA
        CLC
        ADC DIST_LO
        STA DIST_LO
        BCC .LA420
        INC DIST_LO+1
        BCS .LA420
.LA432
        LDX DIST_IDX
        LDA ZP_Y
        SEC
        SBC NPC_Y,X
        BCS .LA446
        STA ABS_TMP
        SEC
        LDA #$00
        SBC ABS_TMP
.LA446
        LDY #$00
        STY DIST_HI
        STY DIST_HI+1
        TAY
        TAX
        INX
.LA451
        DEX
        BEQ .LA463
        TYA
