        SBC SHAPE_XOFF,X
        STA ZP_CX
        SEC
        LDA ZP_CY
        SBC SHAPE_YOFF,X
        STA ZP_CY
        LDA SHAPE_WID,X
        STA BLIT_W
        LDA SHAPE_DX,X
        STA BLIT_DX
        CPX BLIT_SHAPE_PREV
        BEQ .L9E34
        LDA SHAPE_PTR_LO,X
        STA ZP_SHP_DST
        LDA SHAPE_PTR_HI,X
        STA ZP_SHP_DST+1
        LDY SHAPE_HGT,X
        DEY
.L9E13
        LDA (ZP_SHP_DST),Y
        STA SHAPE_BUF,Y
        DEY
        CPY #$FF
        BNE .L9E13
        LDA #$12
        STA ZP_SHP_SRC
        LDA #$B1
        STA ZP_SHP_SRC+1
        LDX BLIT_W
        LDA BLIT_DX
        JSR SHAPE_PRESHIFT
        LDX BLIT_SHAPE
        STX BLIT_SHAPE_PREV
