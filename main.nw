        BEQ .draw
        CLC
        ADC MON_BASE
        CMP #$1E
        BEQ .draw
        CMP #$20
        BEQ .draw
        CMP #$29
        BEQ .draw
        RTS
.draw   LDA DNG_GEOM+$01,X
        STA $06
        STA $08
        LDA DNG_GEOM+$21,X
        STA $07
        LDA DNG_GEOM+$17,X
        STA $09
        JSR LINE_AGAIN
        LDX VIEW_DEPTH
        LDA DNG_GEOM+$0C,X
        STA $08
        JSR LINE_AGAIN
        LDX VIEW_DEPTH
        LDA DNG_GEOM+$21,X
        STA $09
        JMP LINE_AGAIN
@ %def DRAW_AHEAD_OPEN

