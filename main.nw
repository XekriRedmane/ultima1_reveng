        ORG $9093
CMD_TRANSACT
        SUBROUTINE
        ; The Transact command: trade at a shop counter.
        ;
        ; Behavior:
        ;   Refuse if AGGRO is set ("None will talk to thee!").  Map the
        ;   counter NPC ($64..$6C) through NPC_SHOPCLASS to one of six shop
        ;   classes, then prompt Buy/Sell and dispatch through SHOP_BUY_TBL
        ;   / SHOP_SELL_TBL (self-modified JSR) to the per-class handler.
        LDA AGGRO
        BEQ .L90B5
        JSR MSG_PRINT
        DC.B "~None will talk to thee!",0
        RTS
.L90B5
        LDX ZP_X
        LDY ZP_Y
        JSR NPC_AT
        CMP #$64
        BCC .L90D0
        CMP #$6D
        BCS .L90D0
        SEC
        SBC #$64
        TAX
        LDA NPC_SHOPCLASS,X
        STA ZP_T0
        JMP .L90F0
.L90D0
        JSR MSG_PRINT
        DC.B "~Thou art not by a counter!",0
        RTS
.L90F0
        JSR MSG_PRINT
        DC.B "-Buy, Sell: ",0
        JSR KEY_IDLE
        LDX #$09
        STX MON_CH
        CMP #$42
        BEQ .L911E
        CMP #$53
        BNE .L9112
        JMP .L913D
.L9112
        JSR MSG_PRINT
        DC.B "-none",0
        JMP CLR_EOL
.L911E
        JSR MSG_PRINT
        DC.B "-Buy: ",0
        JSR SHOP_OPEN
        LDA SHOP_BUY_TBL,X
        STA BUY_OP
        LDA SHOP_BUY_TBL+1,X
        STA BUY_OP+1
BUY_OP = *+1
        JSR STALE_FFFF
        JMP MAP_DRAW
.L913D
        JSR MSG_PRINT
        DC.B "-Sell: ",0
        JSR SHOP_OPEN
        LDA SHOP_SELL_TBL,X
        STA SELL_OP
        LDA SHOP_SELL_TBL+1,X
        STA SELL_OP+1
SELL_OP = *+1
        JSR STALE_FFFF
        JMP MAP_DRAW
SHOP_OPEN
        JSR CLR_EOL
        LDA ZP_T0
        JSR POPUP_FRAME
        DEC WIN_LEFT
        JSR SHOP_NAME
        JSR PUTCH_NL_COL1
        JSR PUTCH_NL_COL1
        LDA ZP_T0
        ASL
        TAX
        RTS
