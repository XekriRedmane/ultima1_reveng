        ORG $9AB7
BUY_TRANSPORT
        SUBROUTINE
        ; Buy from the transport shop: vehicles parked in the lot.
        ;
        ; Behavior:
        ;   Survey COURT_CELLS for free land/sea/air slots; offer Horse,
        ;   Cart, Raft, Frigate, Air Car (>= $0BB8 gold), Shuttle (only if
        ;   none owned).  A purchase parks the craft by writing
        ;   transport+8 into a free COURT_CELLS slot and bumps
        ;   OWNED_TRANSPORT.
        LDA #$00
        STA AVAIL_LAND
        STA AVAIL_SEA
        STA AVAIL_AIR
        LDX #$06
.L9AC4
        STA BUY_AVAIL,X
        DEX
        BPL .L9AC4
        LDX #$03
.L9ACC
        LDA COURT_CELLS,X
        BNE .L9AD4
        INC AVAIL_LAND
.L9AD4
        CMP #$01
        BNE .L9ADB
        INC AVAIL_SEA
.L9ADB
        CMP #$02
        BNE .L9AE2
        INC AVAIL_AIR
.L9AE2
        DEX
        BPL .L9ACC
        LDA AVAIL_SEA
        ORA AVAIL_AIR
        ORA AVAIL_LAND
        BNE .L9B0E
        JSR MSG_PRINT
        DC.B $7F,$06,"Closed for the day",0
        JSR PAUSE_ABORTABLE
        JMP SHOP_NOTHING
.L9B0E
        LDA AVAIL_SEA
        ORA AVAIL_AIR
        BEQ .L9B46
        JSR MSG_PRINT
        DC.B $7F,$07,"a) Horse   - ",0
        LDX #$01
        JSR TRANSPORT_PRICE
        JSR MSG_PRINT
        DC.B $7F,$07,"b) Cart    - ",0
        LDX #$02
        JSR TRANSPORT_PRICE
.L9B46
        LDA AVAIL_LAND
        BEQ .L9B7B
        JSR MSG_PRINT
        DC.B $7F,$07,"c) Raft    - ",0
        LDX #$03
        JSR TRANSPORT_PRICE
        JSR MSG_PRINT
        DC.B $7F,$07,"d) Frigate - ",0
        LDX #$04
        JSR TRANSPORT_PRICE
.L9B7B
        LDA AVAIL_SEA
        BEQ .L9BCB
        LDA MOVE_CNT+1
        CMP #$B8
        LDA MOVE_CNT+2
        SBC #$0B
        LDA MOVE_CNT+3
        SBC #$00
        LDA MOVE_CNT+4
        SBC #$00
        BCC .L9BCB
        JSR MSG_PRINT
        DC.B $7F,$07,"e) Air Car - ",0
        LDX #$05
