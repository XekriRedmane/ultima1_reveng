        JSR MSG_PRINT
        DC.B $7F,$05,"to watch the ",0
        LDX #$05
        JSR STR_NTH
        DC.W STR_NPCS
        LDA #$2E
        JMP CHAR_OUT
HINT_PRINCESS
        JSR MSG_PRINT
        DC.B " that the princess will give~ great reward to the one who~rescues her, and an extra gift~",$7F,$05,"to an 8th level ace!",0
        RTS
