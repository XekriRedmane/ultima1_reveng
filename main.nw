        ; Move (or, against the throne, rescue the Princess).
        ;
        ; Inputs:
        ;   X,Y  -- step delta from the four entry points (N/S/E/W)
        ;   ZP_X -- player column; column 0 is the throne wall
        ;
        ; Behavior:
        ;   Stepping west (X=$FF) from column 0 toward the King's dais
        ;   means reaching the Princess: if NPC slot 1 is close, run
        ;   PRINCESS_RESCUE.  Otherwise MOVE_STEP probes the target cell,
        ;   refuses a solid one ("Blocked"), else redraws the player glyph
        ;   at the new cell and ticks a turn.
        ;
        ; Clobbers: A, X, Y
        LDX #$00
        LDY #$FF
        JMP .L8AAC
        LDX #$00
        LDY #$01
        JMP .L8AAC
        LDX #$01
        LDY #$00
        JMP .L8AAC
        LDX #$FF
        LDY #$00
.L8AAC
        LDA ZP_X
        BEQ .L8AB3
.L8AB0
        JMP MOVE_STEP
.L8AB3
        CPX #$FF
        BNE .L8AB0
        LDA NPC_X+1
        CMP #$05
        BCC PRINCESS_RESCUE
        JMP .L8BFD
PRINCESS_RESCUE
        JSR POPUP_FRAME
        JSR MSG_PRINT
        DC.B "~ Thou hast saved the Princess~",0
