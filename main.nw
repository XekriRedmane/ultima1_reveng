        DC.W $042B                  ; shape 10
        DC.W $0497                  ; shape 11
        DC.W $04BE                  ; shape 12
        DC.W $0542                  ; shape 13
        DC.W $05C0                  ; shape 14
        DC.W $05F9                  ; shape 15
