\texttt{SPA} enters at [[OVERLAY_ENTRY]], where every overlay is loaded.
What follows is the overlay in address order: entry and the main loop,
the physics and hazards, docking and the ship-berth system, the flight
commands and their delta tables, the dispatch table, the radar and
starfield, firing and the kill counter, the view machinery and enemy AI,
the cell/RNG helpers, the sprite blitter and projection math, and the
file-tail tables.

<<spa entry>>=
        ORG $8956
OVERLAY_ENTRY
        SUBROUTINE
        ; Overlay entry: lift the ship off and run the space loop.
        ;
        ; Behavior:
        ;   Seed the RNG from the saved space position, point DIR_STR_PTR at
        ;   the flight-command names (Thrust/Retro/Clockwise/Counter), zero the
        ;   BSS above the file, run the "10..9..8.." liftoff countdown (any key
        ;   aborts), draw the Shld|Fuel status, seed the 42-star field and the
        ;   enemy grid, place the actors for this sector, then fall into the
        ;   main loop.
        ;
        ; Clobbers: A, X, Y
        LDA PLR_SPACE_X
        STA ZP_RNG
        LDA PLR_SPACE_Y
        STA ZP_RNG+1
        LDA #$19
        STA DIR_STR_PTR
        LDA #$92
        STA DIR_STR_PTR+1
        LDA #$00
        LDY #$F2
.L896E
        STA BSS_TOP,Y
        DEY
        BNE .L896E
        LDA #$00
        STA ZP_PAGE_XOR
        JSR PUTCH_NL_COND
        LDA #$0A
        STA ZP_T0
        LDA #$00
        STA NUM_PAD
LIFTOFF_COUNT
        LDA ZP_T0
        JSR PRINT_NUM8
        DEC ZP_T0
        BEQ .L89A7
        JSR KEY_PENDING
        BNE .L89A7
        JSR MSG_PRINT
        DC.B "..",0
        LDA #$06
        STA ZP_T1
.L899C
        LDA #$00
        JSR VDELAY
        DEC ZP_T1
        BNE .L899C
        BEQ LIFTOFF_COUNT
.L89A7
        JSR KBD_CLEAR
        JSR VIEW_WIPE
        JSR WIN_SAVE
        JSR WIN_STATS
        JSR MSG_PRINT
        DC.B "Shld|Fuel",0
        JSR WIN_RESTORE
        JSR WIN_STATS_DRAW
        LDY #$29
.L89C8
        JSR RND
        STA STAR_X,Y
        JSR RND
        LSR
        STA STAR_Y,Y
        DEY
        BPL .L89C8
        LDA #$05
        STA ZP_X
        STA ZP_Y
        LDA #$08
        STA ZP_CY
.L89E2
        LDA #$08
        STA ZP_CX
.L89E6
        JSR RND_SECTOR
        JSR CELL_DECODE
        LDX RND_MOD
        LDA ENEMY_INIT_LO,X
        STA ENEMY_GRID_LO,Y
        LDA ENEMY_INIT_HI,X
        STA ENEMY_GRID_HI,Y
        DEC ZP_CX
        LDA ZP_CX
        CMP #$02
        BCS .L89E6
        DEC ZP_CY
        LDA ZP_CY
        CMP #$02
        BCS .L89E2
        LDA #$03
        STA ZP_CX
        STA ZP_CY
        JSR CELL_DECODE
        LDA #$00
        STA ENEMY_GRID_LO,Y
        LDA #$C0
        STA ENEMY_GRID_HI,Y
        LDA ZP_X
        STA ZP_CX
        LDA ZP_Y
        STA ZP_CY
        JSR CELL_DECODE
        LDA #$15
        STA ENEMY_GRID_LO,Y
        LDA #$05
        STA ENEMY_GRID_HI,Y
        JSR MSG_PRINT
        DC.B "~Thou hast lifted off!",0
        JSR PLACE_ACTORS
        JSR DRAW_ALL_ACTORS
@

<<spa main loop>>=
        ORG $8A53
SPA_LOOP
        SUBROUTINE
        ; The space main loop: status, input, dispatch, physics.
        ;
        ; Behavior:
        ;   Refresh the status line, poll the keyboard (KEY_GET), translate the
        ;   key to a command (GET_COMMAND).  A flight command (index < 8) is
        ;   gated on fuel and dispatched by self-modifying its handler address
        ;   (from DISPATCH_TBL) into the JMP at DISP_OP.  Other commands jump
        ;   straight to their handler.  Then PHYSICS integrates motion.
        ;
        ; Clobbers: A, X, Y
        LDA MON_CH
        CMP #$02
        BCC .L8A5F
        JSR MSG_PRINT
        DC.B "|",$0E,0
.L8A5F
        JSR KEY_GET
        BEQ PHYSICS
        JSR SPEND_TURN
        JSR GET_COMMAND
        BCS PHYSICS
        CPX #$08
        BCS DISPATCH_PATCH
        LDA PLR_FUEL
        ORA PLR_FUEL+1
        BNE DISPATCH_PATCH
        JSR MSG_PRINT
        DC.B "~No fuel!!~Wilt thou drift forever?!?",0
        JMP PHYSICS
DISPATCH_PATCH
        LDA DISPATCH_TBL,X
        STA DISP_OP
        LDA DISPATCH_TBL+1,X
        STA DISP_OP+1
DISP_OP = *+1
        JMP SPA_LOOP
@

<<spa physics>>=
        ORG $8AB3
PHYSICS
        SUBROUTINE
        ; One physics step: move the ship, the base, and the enemy.
        ;
        ; Behavior:
        ;   Skip while docked.  Add the velocity vector (ZP_VX,ZP_VY) to the
        ;   ship position (SHIP_X,SHIP_Y) on a torus that wraps at $0E/$F4,
        ;   advance the rotation animation timer, redraw, then test the ship
        ;   against the docking base and the enemy craft.  A position match
        ;   with the base means docking (DOCK); with the enemy, a collision
        ;   (COLLIDE).  Falls through to the star-proximity hazard.
        ;
        ; Clobbers: A, X, Y
        LDA IN_DOCK
        BNE SPA_LOOP
PHYSICS_MOVE
        CLC
        LDA REL_X
        ADC ZP_VX
        STA SHIP_X
        CLC
        LDA REL_Y
        ADC ZP_VY
        AND #$7F
        STA SHIP_Y
        LDA SHIP_X
        CMP #$0E
        BCS .L8ADA
        LDA #$F4
        STA SHIP_X
        BNE .L8AE3
.L8ADA
        CMP #$F5
        BCC .L8AE3
        LDA #$0E
        STA SHIP_X
.L8AE3
        DEC DRAW_FLAG
        JSR DRAW_SHIP_NAV
        LDA SHIP_X
        STA ZP_VX
        LDA SHIP_Y
        STA ZP_VY
        LDA HEAD_NEW
        STA HEAD_CUR
        LDA ROT_TIMER
        BEQ .L8B03
        DEC ROT_TIMER
        LDA #$04
.L8B03
        STA ROT_STEP
        INC DRAW_FLAG
        JSR DRAW_SHIP_NAV
        LDA REL_X
        BNE .L8B31
        LDX HEAD_CUR
        LDA REL_Y
        CMP BASE_AXIS,X
        BNE .L8B56
        LDA ZP_VX
        CMP BASE_X
        BNE .L8B56
        CLC
        LDA BASE_Y
        ADC BASE_RADIUS,X
        CMP ZP_VY
        BNE .L8B56
        JMP DOCK
.L8B31
        LDA REL_Y
        BNE .L8B56
        LDX HEAD_CUR
        LDA REL_X
        CMP BASE_AXIS,X
        BNE .L8B56
        LDA ZP_VY
        CMP BASE_Y
        BNE .L8B56
        CLC
        LDA BASE_X
        ADC BASE_RADIUS,X
        CMP ZP_VX
        BNE .L8B56
        JMP DOCK
.L8B56
        LDA ZP_BLIT_HIT
        BNE STAR_HAZARD
        JMP SPA_LOOP
@

<<spa star hazard>>=
        ORG $8B5D
STAR_HAZARD
        SUBROUTINE
        ; Heat damage from flying too near the central star.
        ;
        ; Behavior:
        ;   Measure how close the ship is to the star.  Within the lethal
        ;   radius the ship melts (RESPAWN); within the warning band the shield
        ;   drains (SFX); otherwise the loop continues.
        ;
        ; Clobbers: A, X, Y
        LDA ZP_VX
        STA ACTOR_X+9
        LDA ZP_VY
        STA ACTOR_Y+9
        LDA #$09
        STA DIST_A
        LDA #$08
        STA DIST_B
.L8B71
        JSR ACTOR_DIST
        CMP #$15
        BCC .L8B85
        DEC DIST_B
        BPL .L8B71
        LDA #$0C
        JSR SFX_PLAY
        JMP SPA_LOOP
.L8B85
        LDA DIST_B
        BNE .L8BAE
        JSR MSG_PRINT
        DC.B "Thy ship melts near the star!",0
        JMP RESPAWN
.L8BAE
        CMP #$04
        BCS COLLIDE
        JMP LAND
@

<<spa collide>>=
        ORG $8BB5
COLLIDE
        SUBROUTINE
        ; Ran into an actor: bounce off and take shield damage.
        ;
        ; Behavior:
        ;   Print "Crunch!", negate the velocity (bounce), subtract a shield hit
        ;   scaled by the impact, and RESPAWN if the shield is exhausted.
        ;
        ; Clobbers: A, X, Y
        LDA MON_CH
        CMP #$02
        BCC .L8BBE
        JSR PUTCH_NL_COL1
.L8BBE
        JSR MSG_PRINT
        DC.B "Crunch!",0
        LDA #$0E
        JSR SFX_PLAY
        LDA #$0E
        JSR SFX_PLAY
        LDA #$00
        SEC
        SBC REL_X
        STA REL_X
        LDA #$00
        SEC
        SBC REL_Y
        STA REL_Y
        LDA PLR_SHIELD
        STA ZP_M0
        LDA PLR_SHIELD+1
        STA ZP_M1
        LSR ZP_M1
        ROR ZP_M0
        LSR ZP_M1
        ROR ZP_M0
        CLC
        LDA #$05
        ADC ZP_M0
        STA ZP_M0
        LDA #$00
        ADC ZP_M1
        STA ZP_M1
        SEC
        LDA PLR_SHIELD
        SBC ZP_M0
        STA PLR_SHIELD
        LDA PLR_SHIELD+1
        SBC ZP_M1
        STA PLR_SHIELD+1
        PHP
        BCS .L8C20
        LDA #$00
        STA PLR_SHIELD
        STA PLR_SHIELD+1
.L8C20
        JSR WIN_STATS_DRAW
        PLP
        BCS .L8C44
        JSR MSG_PRINT
        DC.B "~Thy shield is drained!",0
        JMP RESPAWN
.L8C44
        JMP SPA_LOOP
@

<<spa base geom>>=
        ORG $8C47
BASE_RADIUS
        HEX 12ecee12
BASE_AXIS
        HEX ff0201fe
@

<<spa dock>>=
        ORG $8C4F
DOCK
        SUBROUTINE
        ; Docked at a base: pay the fee, refuel, open the bay.
        ;
        ; Behavior:
        ;   Freeze the ship (IN_DOCK), require the 500p docking fee unless the
        ;   coin purse already covers it, then -- if the player is heat-shielded
        ;   (a shuttle) -- open the spacedoors and offer to stow/swap ships.
        ;
        ; Clobbers: A, X, Y
        JSR MSG_PRINT
        DC.B "Docked! Welcome to Base!",0
        LDA #$00
        STA REL_X
        STA REL_Y
        LDA #$01
        STA IN_DOCK
        DEC DRAW_FLAG
        JSR DRAW_SHIP_NAV
        INC DRAW_FLAG
        LDA #$00
        STA ROT_TIMER
        STA ROT_STEP
        JSR DRAW_SHIP_NAV
        LDA PLR_COIN+1
        CMP #$01
        BNE .L8C98
        LDA PLR_COIN
        CMP #$F4
.L8C98
        BCS .L8CED
        JSR MSG_PRINT
        DC.B "~Sorry, but thou canst not~refuel thy ship without~the 500p Docking Fee. ",0
        JSR KEY_WAIT
        JMP SPA_LOOP
.L8CED
        LDA READY_ARMOUR
        CMP #$05
        BEQ STOW_SHIP
        CMP #$04
        BEQ STOW_SHIP
        JSR MSG_PRINT
        DC.B "~The spacedoors open, exposing~thee to a complete vacuum!",0
        JMP RESPAWN
@

<<spa stow ship>>=
        ORG $8D38
STOW_SHIP
        SUBROUTINE
        ; Store the current craft into a free berth at the base.
        ;
        ; Behavior:
        ;   Record the craft's shape, heading and position into one of the four
        ;   berth slots (top/bottom/left/right of the base), refund nothing, and
        ;   fall into CHOOSE_SHIP to pick what to fly next.
        ;
        ; Clobbers: A, X, Y
        CLC
        LDA HEAD_CUR
        ADC #$05
        TAX
        LDA ZP_VX
        STA ACTOR_X,X
        LDA ZP_VY
        STA ACTOR_Y,X
        LDA HEAD_CUR
        STA ACTOR_HEAD,X
        SEC
        LDA PLR_COIN
        SBC #$F4
        STA PLR_COIN
        LDA PLR_COIN+1
        SBC #$01
        STA PLR_COIN+1
        LDA ZP_X
        STA ZP_CX
        LDA ZP_Y
        STA ZP_CY
        LDY READY_ARMOUR+1
        LDA XPORT_FRAME,Y
        STA ACTOR_SHAPE,X
        LDA #$40
        STA ZP_M0
        LDA #$00
        STA ZP_M1
        TYA
        SEC
        SBC #$06
        TAX
.L8D7E
        DEX
        BMI .L8D8C
        ASL ZP_M0
        ROL ZP_M1
        ASL ZP_M0
        ROL ZP_M1
        JMP .L8D7E
.L8D8C
        JSR CELL_DECODE
        LDA ENEMY_GRID_LO,Y
        ORA ZP_M0
        STA ENEMY_GRID_LO,Y
        LDA ENEMY_GRID_HI,Y
        ORA ZP_M1
        STA ENEMY_GRID_HI,Y
        JSR CELL_DECODE
@

<<spa choose ship>>=
        ORG $8DA2
CHOOSE_SHIP
        SUBROUTINE
        ; "Choose thy ship": pick a berthed craft to board.
        ;
        ; Behavior:
        ;   Read a direction key; if a craft is berthed in that slot, board it
        ;   (BOARD_SHIP), else complain.  The four ACTOR_SHAPE+4..+8 flags mark
        ;   which berths are occupied.
        ;
        ; Clobbers: A, X, Y
        JSR MSG_PRINT
        DC.B "~Choose thy ship: ",0
.L8DB8
        JSR KEY_GET
        BEQ .L8DB8
        JSR KEY_ALIAS
        CMP #$0B
        BNE .L8DC7
        JMP .L8DE2
.L8DC7
        CMP #$0A
        BNE .L8DCE
        JMP .L8E0D
.L8DCE
        CMP #$15
        BNE .L8DD5
        JMP .L8E38
.L8DD5
        CMP #$08
        BNE .L8DDC
        JMP .L8E62
.L8DDC
        JSR QUERY_MARK
        JMP CHOOSE_SHIP
.L8DE2
        LDA ACTOR_SHAPE+7
        BNE .L8DEA
        JMP .L8E8B
.L8DEA
        JSR MSG_PRINT
        DC.B "~Thou art in the top ship.",0
        LDX #$07
        JMP BOARD_SHIP
.L8E0D
        LDA ACTOR_SHAPE+5
        BEQ .L8E8B
        JSR MSG_PRINT
        DC.B "~Thou art in the bottom ship.",0
        LDX #$05
        JMP BOARD_SHIP
.L8E38
        LDA ACTOR_SHAPE+8
        BEQ .L8E8B
        JSR MSG_PRINT
        DC.B "~Thou art in the right ship.",0
        LDX #$08
        JMP BOARD_SHIP
.L8E62
        LDA ACTOR_SHAPE+6
        BEQ .L8E8B
        JSR MSG_PRINT
        DC.B "~Thou art in the left ship.",0
        LDX #$06
        JMP BOARD_SHIP
.L8E8B
        JSR MSG_PRINT
        DC.B "~That port is not available.",0
        JMP CHOOSE_SHIP
@

<<spa board ship>>=
        ORG $8EAE
BOARD_SHIP
        SUBROUTINE
        ; Board the chosen craft: load its fuel, shield and heading.
        ;
        ; Behavior:
        ;   Map the craft's shape to its CRAFT_TYPE, set READY_TRANSPORT, copy
        ;   the berth's heading and position into the live ship state, clear the
        ;   berth, and load this craft's starting fuel/shield from SHIP_FUEL and
        ;   SHIP_SHIELD.
        ;
        ; Clobbers: A, X, Y
        LDA ACTOR_SHAPE,X
        LDY #$02
.L8EB3
        CMP CRAFT_TYPE,Y
        BEQ .L8EBC
        DEY
        BPL .L8EB3
        INY
.L8EBC
        TYA
        PHA
        CLC
        ADC #$06
        STA READY_ARMOUR+1
        LDA ACTOR_X,X
        STA ZP_VX
        LDA ACTOR_Y,X
        STA ZP_VY
        LDA ACTOR_HEAD,X
        STA HEAD_CUR
        STA HEAD_NEW
        LDA #$00
        STA ACTOR_SHAPE,X
        STA ACTOR_HEAD,X
        LDA #$FF
        STA ACTOR_X,X
        STA ACTOR_Y,X
        LDA #$BF
        STA ZP_M0
        LDA #$FF
        STA ZP_M1
        LDA ZP_X
        STA ZP_CX
        LDA ZP_Y
        STA ZP_CY
        PLA
        PHA
        TAX
.L8EFA
        DEX
        BMI .L8F0A
        SEC
        ROL ZP_M0
        ROL ZP_M1
        SEC
        ROL ZP_M0
        ROL ZP_M1
        JMP .L8EFA
.L8F0A
        JSR CELL_DECODE
        LDA ENEMY_GRID_LO,Y
        AND ZP_M0
        STA ENEMY_GRID_LO,Y
        LDA ENEMY_GRID_HI,Y
        AND ZP_M1
        STA ENEMY_GRID_HI,Y
        JSR CELL_DECODE
        PLA
        TAX
        LDA SHIP_FUEL,X
        STA PLR_FUEL
        LDA SHIP_FUEL+3,X
        STA PLR_FUEL+1
        LDA SHIP_SHIELD,X
        STA PLR_SHIELD
        LDA SHIP_SHIELD+3,X
        STA PLR_SHIELD+1
        JSR WIN_STATS_DRAW
        JMP SPA_LOOP
@

<<spa ship tables>>=
        ORG $8F40
SHIP_FUEL
        HEX e8c488030913
SHIP_SHIELD
        HEX e888e8031303
