\centering
\includegraphics[width=\textwidth]{images/dng_monster_shapes.png}
\caption{The 25 [[DNG]] vector shapes at full scale. Humanoid
monsters, beasts, the treasure chest (11), a sack (21) and the
gazer/eye (17); the sparse tiles are the chest/coffin and
ladder-cell glyphs and the unused sentinel slots.}
\end{figure}

<<dng shapes>>=
