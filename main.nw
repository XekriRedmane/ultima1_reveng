SELL_FLAG       EQU $951C       ; sell loop: any-item flag (patched)
NUM_T           EQU $AA67       ; NUM_INPUT scratch
NUM_UNDO        EQU $AA63       ; NUM_INPUT backspace buffer
NUM_UNDO2       EQU $AA65
AMOUNT          EQU $AA69       ; NUM_INPUT result, 16-bit
BUY_AVAIL       EQU $AA6B       ; transport menu availability flags
@

<<twn entry>>=
        ORG $8956
OVERLAY_ENTRY
        SUBROUTINE
        ; Overlay entry: load the town map and run the town loop.
        ;
        ; Behavior:
        ;   Set the player position from the saved zero page, copy the
        ;   gendered address word by PLR_SEX, reduce PLR_PLACE to a town
        ;   index (mod $15, then -$0D), BLOAD TCMAPS and MAPCHARS, copy the
        ;   chosen 3-page map record into TOWN_MAP, draw it, then fall into
        ;   the dispatch loop.  KEY_IDLE polls with a timeout so the town
        ;   animates (TOWN_TICK) while waiting for a key.
        ;
        ; Clobbers: A, X, Y
        LDA #$11
        STA ZP_Y
        LDA #$13
        STA ZP_X
        LDA PLR_SEX
        BEQ .L896E
        LDX #$05
.L8965
        LDA STR_GENDER_F,X
        STA STR_GENDER_M,X
        DEX
        BPL .L8965
.L896E
        LDA #$00
        STA AGGRO
        STA DIR_STR_PTR+1
        STA PUB_VISITS
        LDA PLR_PLACE
.L897C
        CMP #$15
        BCC .L8984
        SBC #$15
        BNE .L897C
.L8984
        SEC
        SBC #$0D
        STA MAP_INDEX
        PHA
.L898B
        JSR MLIB_SET_PREFIX
        DC.B "TCMAPS",0
        LDA #$40
        LDY #$00
        JSR FILE_LOAD_AT
        JSR DISK_PROMPT
        BCS .L898B
.L89A1
        JSR MLIB_SET_PREFIX
        DC.B "MAPCHARS",0
        LDA #$B0
        LDY #$00
        JSR FILE_LOAD_AT
        JSR DISK_PROMPT
        BCS .L89A1
        PLA
        ASL
        TAX
        LDA TCMAPS_DIR+4,X
        STA MAP_SRC
        LDA TCMAPS_DIR+5,X
        STA MAP_SRC+1
        LDY #$03
        LDX #$00
.L89CC
MAP_SRC = *+1
        LDA STALE_FFFF,X
MAP_DST = *+2
        STA TOWN_MAP,X
        DEX
        BNE .L89CC
        INC MAP_SRC+1
        INC MAP_DST
        DEY
        BNE .L89CC
        JSR MAP_DRAW
        JMP TWN_DISPATCH
MAP_PROMPT
        JSR TEXT_SCROLL
        LDA #$0E
        JSR CHAR_OUT
TWN_LOOP
        JSR STATS_VALUES
        JSR KEY_IDLE
        BNE .L8A16
        LDA #$00
        STA IDLE_MSG
        JSR CURSOR_COL1
        LDA #$20
        JSR CHAR_OUT
        JSR TOWN_TICK
        JSR CMD_PASS
        LDA IDLE_MSG
        BNE MAP_PROMPT
        LDA #$17
        STA MON_CV
        JSR CURSOR_COL1
        JMP TWN_LOOP
.L8A16
        JSR GET_COMMAND
        BCS MAP_PROMPT
        RTS
KEY_IDLE
        LDX #$80
.L8A1E
        JSR KEY_GET
        BNE .L8A26
        DEX
        BNE .L8A1E
.L8A26
        TAX
        RTS
TWN_DISPATCH
        LDA PLR_HITS
        ORA PLR_HITS+1
        BEQ TWN_DEATH
        LDA PLR_FOOD
        ORA PLR_FOOD+1
        BNE .L8A3E
TWN_DEATH
        JSR TEXT_SCROLL
        JMP RESPAWN
.L8A3E
        JSR MAP_PROMPT
        LDA CMD_TBL,X
        STA DISP_OP
        LDA CMD_TBL+1,X
        STA DISP_OP+1
DISP_OP = *+1
        JSR STALE_FFFF
        JSR TOWN_TICK
        JMP TWN_DISPATCH
@

\subsection{The command table and dispatch}

Like every overlay, \texttt{TWN} reads a command through the engine
[[GET_COMMAND]] (which returns $X = 2\times\text{index}$) and jumps
through a word table, [[CMD_TBL]], by self-modifying the operand of a
[[JSR]]. Most of the 26 commands are no-ops in town and point at the
engine's [[QUERY_MARK]] (the ``Huh?'' beep); the rest are the
town-mode handlers below. Accelerator and Noise reuse the engine's
sound toggles.

<<twn command table>>=
        ORG $8A56
CMD_TBL
        DC.W CMD_MOVE
        DC.W $8A90
        DC.W $8A96
        DC.W $8A9C
        DC.W CMD_PASS
        DC.W SOUND_TOGGLE
        DC.W CMD_ATTACK
        DC.W QUERY_MARK
        DC.W CMD_CAST
        DC.W CMD_DROP
        DC.W QUERY_MARK
        DC.W QUERY_MARK
        DC.W CMD_GET
        DC.W QUERY_MARK
        DC.W CMD_INFORM
        DC.W QUERY_MARK
        DC.W SFX_TOGGLE
        DC.W QUERY_MARK
        DC.W CMD_QUIT
        DC.W CMD_READY
        DC.W CMD_STEAL
        DC.W CMD_TRANSACT
        DC.W CMD_UNLOCK
        DC.W QUERY_MARK
        DC.W QUERY_MARK
        DC.W CMD_ZTATS
@

<<twn move>>=
        ORG $8A8A
CMD_MOVE
        SUBROUTINE
        ; The four movement commands and the Pass turn.
        ;
        ; Inputs:
        ;   X = 2*command (0..3); the load below picks the step vector.
        ;
        ; Behavior:
        ;   Add the step to (ZP_X,ZP_Y); CELL_PROBE the target.  Walking
        ;   off the 38x18 edge (ZP_TX>=$26 or ZP_TY>=$12) leaves town via
        ;   EXIT_TO_OUT.  A blocked cell prints "Blocked"; an open one
        ;   erases the old @ and redraws it at the new cell.  Every move
        ;   (and Pass) spends a turn through TICK_SND.
        ;
        ; Clobbers: A, X, Y
        LDX #$00
        LDY #$FF
        BNE .L8AA0
        LDX #$00
        LDY #$01
        BNE .L8AA0
        LDX #$01
        LDY #$00
        BEQ .L8AA0
        LDX #$FF
        LDY #$00
.L8AA0
        TXA
        CLC
        ADC ZP_X
        STA ZP_TX
        TAX
        TYA
        CLC
        ADC ZP_Y
        STA ZP_TY
        TAY
        JSR CELL_PROBE
        BCS .L8AD8
        LDA ZP_TX
        CMP #$26
        BCS .L8ABF
        LDA ZP_TY
        CMP #$12
        BCC .L8AC2
.L8ABF
        JMP EXIT_TO_OUT
.L8AC2
        LDA #$0E
        JSR SFX_PLAY
        JSR CURSOR_COL1
        JSR MSG_PRINT
        DC.B "Blocked",0
        JMP CMD_PASS
.L8AD8
        LDX ZP_X
        LDY ZP_Y
        LDA #$20
        JSR PLOT_GLYPH
        LDX ZP_TX
        STX ZP_X
        LDY ZP_TY
        STY ZP_Y
        LDA #$7B
        JSR PLOT_GLYPH
CMD_PASS
        LDY #$01
        LDA #$10
        JSR TICK_SND
.L8AF5
        JSR SFX_DRAIN
        BNE .L8AF5
        RTS
@

<<twn attack>>=
        ORG $8AFB
CMD_ATTACK
        SUBROUTINE
        ; The Attack command: strike an adjacent townsperson.
        ;
        ; Behavior:
        ;   Echo the readied weapon (a bare-hands or magic weapon refuses).
        ;   Read a direction, then march along it: each cell that holds an
        ;   NPC is a to-hit roll against PLR_AGI-scaled armour; a hit rolls
        ;   damage (weapon-scaled) into NPC_HP, prints it, and "Killed!"
        ;   frees the slot and awards experience.
        ;
        ; Clobbers: A, X, Y
        JSR MSG_PRINT
        DC.B "with ",0
        LDX READY_WEAPON
        JSR STR_NTH
        DC.W STR_WEAPONS_S
        LDX READY_WEAPON
        CPX #$04
        BEQ .L8B1B
        CPX #$08
        BCC .L8B1E
        CPX #$0B
        BCS .L8B1E
.L8B1B
        JMP QUERY_MARK
.L8B1E
        JSR MSG_PRINT
        DC.B ": ",0
        JSR KEY_IDLE
        BEQ .L8B49
        JSR KEY_ALIAS
        LDX #$00
        LDY #$00
        CMP #$0B
        BNE .L8B37
        DEY
        BNE .L8B56
.L8B37
        CMP #$0A
        BNE .L8B3E
        INY
        BNE .L8B56
.L8B3E
        CMP #$15
        BNE .L8B45
        INX
        BNE .L8B56
.L8B45
        CMP #$08
        BEQ .L8B55
.L8B49
        JSR MSG_PRINT
        DC.B "Nothing",0
        RTS
.L8B55
        DEX
.L8B56
        STX ZP_DX
        STY ZP_DY
        JSR GET_COMMAND
        JSR PUTCH_NL_COND
        LDX READY_WEAPON
        LDA WEAPON_HITKIND,X
        STA ATK_CNT
        LDA ZP_X
        STA ZP_TX
        LDA ZP_Y
        STA ZP_TY
.L8B71
        LDA ZP_TX
        CLC
        ADC ZP_DX
        STA ZP_TX
        TAX
        LDA ZP_TY
        CLC
        ADC ZP_DY
        STA ZP_TY
        TAY
        JSR CELL_PROBE
        PHP
        CMP #$16
        BCC .L8B99
        PLP
        PHP
        BCS .L8B99
        PLP
        CMP #$30
        BCC .L8B9F
        CMP #$36
        BCS .L8B9F
        JMP .L8BB0
.L8B99
        PLP
        DEC ATK_CNT
        BNE .L8B71
.L8B9F
        LDA #$06
