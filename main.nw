<<spa land>>=
        ORG $8F4C
LAND
        SUBROUTINE
        ; Land on a planet (shuttles only) and exit to the overworld.
        ;
        ; Behavior:
        ;   Only the space shuttle is heat-shielded for re-entry; any other
        ;   craft burns up (RESPAWN).  A shuttle lands safely and EXIT_TO_OUT
        ;   returns the player to the overworld.
        ;
        ; Clobbers: A, X, Y
        LDA READY_ARMOUR+1
        CMP #$06
        BEQ .L8F8D
        JSR MSG_PRINT
        DC.B "Only space shuttles are heat~shielded for landings!",0
        JMP RESPAWN
.L8F8D
        JSR MSG_PRINT
        DC.B "Thou hast landed safely! ",0
        JMP EXIT_TO_OUT
@

<<spa thrust>>=
        ORG $8FAD
CMD_THRUST
        SUBROUTINE
        ; Thrust: accelerate the ship along its heading.
        ;
        ; Behavior:
        ;   Add the heading's THRUST_DX/THRUST_DY delta to the velocity vector,
        ;   clamp each component (CLAMP_VEL), play the engine sound, burn fuel,
        ;   and re-enter PHYSICS.
        ;
        ; Clobbers: A, X, Y
        LDA IN_DOCK
        BEQ .L8FBA
        LDA #$00
        JSR SFX_PLAY
        JMP COLLIDE
.L8FBA
        LDX HEAD_CUR
        CLC
        LDA REL_X
        ADC THRUST_DX,X
        JSR CLAMP_VEL
        STA REL_X
        CLC
        LDA REL_Y
        ADC THRUST_DY,X
        JSR CLAMP_VEL
        STA REL_Y
        LDA #$00
        JSR SFX_PLAY
        LDA #$08
        ADC ROT_TIMER
        AND #$7F
        STA ROT_TIMER
        LDA #$05
        JSR FUEL_BURN
        JSR MSG_PRINT
        DC.B "|",$0E,0
        JMP PHYSICS
@

<<spa thrust tables>>=
        ORG $8FF4
THRUST_DX
        HEX 000200fe
THRUST_DY
        HEX ff000100
@

<<spa clamp vel>>=
        ORG $8FFC
CLAMP_VEL
        SUBROUTINE
        ; Clamp a signed velocity/position component to its bounds.
        ;
        ; Behavior:
        ;   Limit A to the range [+8 .. -8] (i.e. $08..$F8), holding the value
        ;   at the rail when it would overflow.  Used for both velocity and the
        ;   torus-wrapped projection.
        ;
        ; Outputs: A = clamped value
        ; Clobbers: A
        CMP #$80
        BCS .L9007
        CMP #$09
        BCC .L900D
        LDA #$08
        RTS
.L9007
        CMP #$F8
        BCS .L900D
        LDA #$F8
.L900D
        RTS
@

<<spa retro>>=
        ORG $900E
CMD_RETRO
        SUBROUTINE
        ; Retro: decelerate (thrust opposite the heading).
        ;
        ; Behavior:
        ;   Like CMD_THRUST but with the RETRO_DX/RETRO_DY deltas, and it also
        ;   clears the rotation timer so the ship faces forward.
        ;
        ; Clobbers: A, X, Y
        LDX HEAD_CUR
        CLC
        LDA REL_X
        ADC RETRO_DX,X
        JSR CLAMP_VEL
        STA REL_X
        CLC
        LDA REL_Y
        ADC RETRO_DY,X
        JSR CLAMP_VEL
        STA REL_Y
        LDA #$00
        JSR SFX_PLAY
        LDA #$00
        STA ROT_TIMER
        STA IN_DOCK
        LDA #$05
        JSR FUEL_BURN
        JSR MSG_PRINT
        DC.B "|",$0E,0
        JMP PHYSICS
@

<<spa retro tables>>=
        ORG $9046
RETRO_DX
        HEX 00fe0002
RETRO_DY
        HEX 0100ff00
@

<<spa rotate>>=
        ORG $904E
CMD_CLOCKWISE
        SUBROUTINE
        ; Clockwise / Counter-Clockwise: turn the ship 90 degrees.
        ;
        ; Behavior:
        ;   Increment (clockwise) or decrement (counter) the heading mod 4, kick
        ;   the rotation animation, and re-enter the physics at PHYSICS_MOVE.
        ;   CMD_COUNTER follows immediately.
        ;
        ; Clobbers: A, X, Y
        LDA IN_DOCK
        BEQ .L9056
        JMP COLLIDE
.L9056
        LDA HEAD_CUR
        CLC
        ADC #$01
        AND #$03
        STA HEAD_NEW
        LDA #$00
        STA ROT_TIMER
        LDA #$02
        JSR FUEL_BURN
        JSR MSG_PRINT
        DC.B "|",$0E,0
        JMP PHYSICS_MOVE
CMD_COUNTER
        LDA IN_DOCK
        BEQ .L907C
        JMP COLLIDE
.L907C
        LDX HEAD_CUR
        DEX
        BPL .L9084
        LDX #$03
.L9084
        STX HEAD_NEW
        LDA #$00
        STA ROT_TIMER
        LDA #$02
        JSR FUEL_BURN
        JSR MSG_PRINT
        DC.B "|",$0E,0
        JMP PHYSICS_MOVE
@

<<spa hyper blocked>>=
        ORG $909A
CMD_HYPER_BLOCKED
        SUBROUTINE
        ; HyperJump is rejected in overhead-nav view.
        ;
        ; Behavior:
        ;   Beep and explain that HyperJump only works in front view, then
        ;   return to the loop.
        ;
        ; Clobbers: A
        JSR QUERY_MARK
        JSR MSG_PRINT
        DC.B "~HyperJump can only be~used in front view mode.|",$0E,0
        JMP PHYSICS
@

<<spa scan>>=
