        SUBROUTINE
        ; Reset the radar pan offset to centre on the ship.
        ;
        ; Behavior:
        ;   Park the pan position at the screen middle and zero the pan
        ;   deltas, so the next starfield frame draws centred on the ship.
        ;
        ; Clobbers: A
        LDA #$80
        STA ZP_RET_CNT
        STA ZP_RET_X
        LSR
        STA ZP_RET_Y
        LDA #$00
        STA PAN_DX
        STA PAN_DY
        RTS
@

