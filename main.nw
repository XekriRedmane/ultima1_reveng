<<spa hit enemy>>=
        ORG $96BD
EXPLODE
        SUBROUTINE
        ; A hit lands: flash, award exp, and count the kill.
        ;
        ; Behavior:
        ;   EXPLODE plays the hit flash.  HIT_ENEMY drains the enemy's HP; once
        ;   it dies it awards +100 experience (capped at 9999) and increments
        ;   PLR_VESSELS -- the destroyed-craft counter the castle's princess
        ;   rescue gates on.  Reaching exactly 20 ($14) announces "the rank of
        ;   Space Ace"; beyond that prints "still a Space Ace".
        ;
        ; Modifies: PLR_EXP, PLR_VESSELS
        ; Clobbers: A, X, Y
        LDA #$00
        JSR ENEMY_PROJECT
        JSR FRAME_SYNC
        LDA #$80
        JSR ENEMY_PROJECT
        JSR FRAME_SYNC
        INC DRAW_FLAG
        BMI EXPLODE
        LDA #$02
        STA AI_AGGRO
        LDA #$90
        STA AI_RET_X
        STA AI_RET_Y
        JSR MSG_PRINT
        DC.B "~Hit!!!",0
        LDA ZP_X
        STA ZP_CX
        LDA ZP_Y
        STA ZP_CY
        JSR CELL_DECODE
        DEC CELL_ENEMY
        BPL .L9700
        INC CELL_ENEMY
        JMP RETICLE_RESET
.L9700
        LDA ENEMY_GRID_HI,Y
        SEC
        SBC #$40
        STA ENEMY_GRID_HI,Y
        CLC
        LDA PLR_EXP
        ADC #$64
        STA PLR_EXP
        LDA PLR_EXP+1
        ADC #$00
        STA PLR_EXP+1
        LDA PLR_EXP+1
        CMP #$27
        BNE .L9726
        LDA PLR_EXP
        CMP #$10
.L9726
        BCC .L9732
        LDA #$0F
        STA PLR_EXP
        LDA #$27
        STA PLR_EXP+1
.L9732
        INC PLR_VESSELS
        BNE .L973A
        DEC PLR_VESSELS
.L973A
        LDA PLR_VESSELS
        CMP #$14
        BCC .L9763
        BEQ .L9766
        JSR MSG_PRINT
        DC.B "~Thou art still a Space Ace!",0
.L9763
        JMP RETICLE_RESET
.L9766
        JSR POPUP_FRAME
        LDA #$07
        STA MON_CV
        LDA #$06
        STA MON_CH
        JSR MSG_PRINT
        DC.B "Thou hast achieved~~",0
        LDA #$09
        STA MON_CH
        JSR MSG_PRINT
        DC.B "the rank of~~",0
        LDA #$0A
        STA MON_CH
        JSR MSG_PRINT
        DC.B "Space Ace!",0
        JSR PAUSE_ABORTABLE
        JSR WIN_RESTORE
        JSR VIEW_WIPE
@

<<spa reticle reset>>=
