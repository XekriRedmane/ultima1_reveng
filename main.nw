<<twn entry>>=
        ORG $8956
OVERLAY_ENTRY
        SUBROUTINE
        ; Overlay entry: load the town map and run the town loop.
        ;
        ; Behavior:
        ;   Set the player position from the saved zero page, copy the
        ;   gendered address word by PLR_SEX, reduce PLR_PLACE to a town
        ;   index (mod $15, then -$0D), BLOAD TCMAPS and MAPCHARS, copy the
        ;   chosen 3-page map record into TOWN_MAP, draw it, then fall into
        ;   the dispatch loop.  KEY_IDLE polls with a timeout so the town
        ;   animates (TOWN_TICK) while waiting for a key.
        ;
        ; Clobbers: A, X, Y
        LDA #$11
        STA ZP_Y
        LDA #$13
        STA ZP_X
        LDA PLR_SEX
        BEQ .L896E
        LDX #$05
.L8965
        LDA STR_GENDER_F,X
        STA STR_GENDER_M,X
        DEX
        BPL .L8965
.L896E
        LDA #$00
        STA AGGRO
        STA DIR_STR_PTR+1
        STA PUB_VISITS
        LDA PLR_PLACE
.L897C
        CMP #$15
        BCC .L8984
        SBC #$15
        BNE .L897C
.L8984
        SEC
        SBC #$0D
        STA MAP_INDEX
        PHA
.L898B
        JSR MLIB_SET_PREFIX
        DC.B "TCMAPS",0
        LDA #$40
        LDY #$00
        JSR FILE_LOAD_AT
        JSR DISK_PROMPT
        BCS .L898B
.L89A1
        JSR MLIB_SET_PREFIX
