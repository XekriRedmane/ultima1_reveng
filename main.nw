; --- More STUPH state and zero page ---
SOUND_ON        EQU $1580       ; STUPH: master sound flag
SFX_ON          EQU $1581       ; STUPH: sound-effects flag
ZP_LIST         EQU $67         ; MENU_PICK: owned-array pointer
ZP_ROWS         EQU $69         ; alias: MENU_PICK row count
