        LDA PLR_HITS+1
        STA ZP_M3
        LDA #$0A
        STA ZP_M0
        LDA #$00
        JSR DIV16
        LDA ZP_M3
        STA SCENE_T1
        LDA ZP_M2
        STA SCENE_T0
        SEC
        LDA PLR_HITS
        SBC SCENE_T0
        STA PLR_HITS
