        LDA #$00
        STA PLR_HITS
        STA PLR_HITS+1
        JSR STATS_VALUES
        JSR POPUP_TEXT
        DC.B "||",$A0,$D4,$E8,$EF,$F5,$A0,$E8,$E1,$F3,$F4,$A0,$E2,$E5,$E5,$EE,$A0,$E4,$E5,$E6,$E5,$E1,$F4,$E5,$E4,$A0,$E2,$F9,"|",$A0,$A0,$A0,$A0,$A0,$CD,$EF,$EE,$E4,$E1,$E9,$EE,$A0,$F4,$E8,$E5,$A0,$D7,$E9,$FA,$E1,$F2,$E4,$A1,"|||",$A0,$A0,$D4,$C8,$C5,$A0,$D5,$CE,$C9,$D6,$C5,$D2,$D3,$C5,$A0,$C9,$D3,$A0,$C4,$CF,$CF,$CD,$C5,$C4,$A1,$A1,0
