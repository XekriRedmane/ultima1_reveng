\centering
\includegraphics[width=0.8\textwidth]{images/mapchars_font.png}
\caption{The \texttt{MAPCHARS} glyph bank, 128 glyphs in index
order. Wall and counter strips at the top; the inverse shop-sign
alphabet in the middle; a few special figures at the end.}
\label{fig:mapchars-font}
\end{figure}

