        JSR KEY_IDLE
        CMP #$53
        BEQ .L8F80
        CMP #$57
        BEQ .L8F80
        CMP #$41
        BEQ .L8F80
        RTS
.L8F80
        JSR READY_CMD
        JMP MAP_DRAW
@

