<<spa reticle draw>>=
        ORG $93FE
RETICLE_DRAW
        SUBROUTINE
        ; Erase the old reticle box and draw it at the new position.
        ;
        ; Behavior:
        ;   If the reticle moved, XOR-erase the previous box, record the new
        ;   centre, and stroke a small box of dots around it (RETICLE_PLOT).
        ;
        ; Clobbers: A, X, Y
        LDX CUR_RET_X
        LDY CUR_RET_Y
        CPX ZP_RET_X
        BNE .L940C
        CPY ZP_RET_Y
        BEQ RETICLE_PLOT
.L940C
        LDA #$04
        JSR .L941D
RETICLE_PLOT
        LDX ZP_RET_X
        STX CUR_RET_X
        LDY ZP_RET_Y
        STY CUR_RET_Y
        LDA #$07
.L941D
        STX ZP_PX
        DEY
        DEY
        STY ZP_PY
        JSR COLOR_SET
        JSR PLOT
        INC ZP_PY
        JSR PLOT
        INC ZP_PY
        JSR PLOT
        INC ZP_PY
        JSR PLOT
        INC ZP_PY
        JSR PLOT
        DEC ZP_PY
        DEC ZP_PY
        DEC ZP_PX
        DEC ZP_PX
        JSR PLOT
        CLC
        LDA ZP_PX
        ADC #$04
        STA ZP_PX
        JMP PLOT
RNG_TO_PIXEL
        LDA RNG_SAVE
        STA ZP_RNG
        LDA RNG_SAVE+1
        STA ZP_RNG+1
        LDA #$C8
        STA ZP_RET_CNT
        RTS
@

<<spa rng pixel>>=
        ORG $9461
RNG_STEP_PIX
        SUBROUTINE
        ; Advance the RNG and fold it into a signed pixel delta.
        ;
        ; Behavior:
        ;   RNG_STEP_PIX runs one Fibonacci step on ZP_RNG and returns a small
        ;   signed offset used to jitter the starfield.
        ;
        ; Outputs: A = signed pixel delta
        ; Clobbers: A, X
        CLC
        LDA ZP_RNG
        ADC #$09
        ADC ZP_RNG+1
        LDX ZP_RNG
        STA ZP_RNG
        STX ZP_RNG+1
        LSR
        BCC .L9475
        LSR
        SBC #$20
        RTS
.L9475
        ASL
        RTS
@

<<spa idle poll>>=
        ORG $9477
IDLE_TICK
        SUBROUTINE
        ; Poll for a key while animating the starfield.
        ;
        ; Behavior:
        ;   IDLE_TICK flashes the cursor and pans the starfield one frame;
        ;   IDLE_POLL repeats it up to SCAN_TIMEOUT times waiting for a key, so
        ;   the view drifts when the player is idle.
        ;
        ; Outputs: Z clear if a key is waiting
        ; Clobbers: A, X, Y
        JSR CURSOR_FLASH
        JSR STARFIELD_PAN
        JSR KEY_PENDING
        BNE .L9483
        RTS
.L9483
        JMP KEY_WAIT
IDLE_POLL
        LDA #$32
        STA SCAN_TIMEOUT
.L948B
        JSR IDLE_TICK
        BNE .L9495
        DEC SCAN_TIMEOUT
        BNE .L948B
.L9495
        RTS
SCAN_TIMEOUT
        HEX 32
@

