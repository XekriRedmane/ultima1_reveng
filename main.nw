        JSR CLEAR_MSGS
        JSR MSG_PRINT
        DC.B $7F,$0B,"Sold!",0
        RTS
SHOP_DONE
        JSR CLEAR_MSGS
        JSR MSG_PRINT
        DC.B $7F,$0B,"Done!",0
        RTS
SHOP_TOOPOOR
        JSR CLEAR_MSGS
        JSR MSG_PRINT
        DC.B "  Thou canst not afford it!   ",0
        JSR BEEP_HUH
        JMP FLUSH_KEYS
PRICE_BY_WIS
        LDA #$C8
        SEC
        SBC PLR_WIS
        LSR
        LSR
        LSR
        LSR
        LSR
        STA ZP_T0
        JMP PRICE_MUL
PRICE_BY_INT
        LDA #$C8
        SEC
        SBC PLR_INT
        LSR
        LSR
        STA ZP_T0
        JMP PRICE_MUL
PRICE_WEAPON
        LDA #$FF
        SEC
        SBC PLR_INT
        STA ZP_T0
        LDA ITEM_COST,X
        TAX
        JSR PRICE_MUL
        LDA PRICE+1
        CLC
        ADC #$05
        STA PRICE
        LDA #$00
        STA PRICE+1
        RTS
PRICE_TRANSPORT
        LDA #$C8
        SEC
        SBC PLR_INT
        LDY #$00
.L9EC7
        INY
        SEC
        SBC #$05
        BCS .L9EC7
        STY ZP_T0
        LDA ITEM_COST,X
        TAX
PRICE_MUL
        LDA #$00
        STA PRICE
        STA PRICE+1
.L9EDB
        DEX
        CPX #$FF
        BEQ .L9EF4
        LDA PRICE
        CLC
        ADC ZP_T0
        STA PRICE
        LDA PRICE+1
        ADC #$00
        STA PRICE+1
        JMP .L9EDB
.L9EF4
        RTS
