; --- The keyboard type-ahead count (STUPH zero page) ---
ZP_KEY_CNT      EQU $78         ; pending keys in the queue
@

<<miu1 inline text readers>>=
        ORG $8037
MSG_GETC
        SUBROUTINE
        ; Fetch the next message byte.
        ;
        ; Behavior:
        ;   Pre-increment MSG_PTR (the captured caller return
        ;   address) and load the byte it points at.
        INC MSG_PTR
        BNE .go
        INC MSG_PTR+1
MSG_PTR = *+1
.go     LDA $0200                       ; stale operand (inline cursor)
        RTS
STR_GETC
        SUBROUTINE
        ; Fetch the next string-table byte.
        ;
        ; Behavior:
        ;   Load through STR_PTR, then post-increment it.
STR_PTR = *+1
        LDA $0200                       ; stale operand (table cursor)
        INC STR_PTR
        BNE .rts
        INC STR_PTR+1
.rts    RTS
PRINT_HEX
        SUBROUTINE
        ; Print A as two hex digits.
        ;
        ; Behavior:
        ;   High nibble through PRINT_DIGIT, then the low nibble
        ;   falls through into it; both exit via CHAR_OUT.
        PHA
        LSR
        LSR
        LSR
        LSR
        JSR PRINT_DIGIT
        PLA
PRINT_DIGIT
        AND #$0F
        ORA #$30                        ; '0'-'9'
        CMP #$3A
        BCC CHAR_OUT
        ADC #$06                        ; carry set: fold into 'A'-'F'
CHAR_OUT
        ; draw one character and advance the cursor
        JSR FONT_DRAW
        INC MON_CH
PUTCH_RTS
        RTS
PUTCH
        SUBROUTINE
        ; Print one character, interpreting layout control codes.
        ;
        ; Inputs:
        ;   A - character; codes $7C-$7E control layout
        ;
        ; Behavior:
        ;   Below $7C: draw it. $7C '|': newline. $7E '~': newline
        ;   then column 1. $7D '}': newline only if past column 1,
        ;   then column 1.
        AND #$7F
        CMP #$7C
        BCC CHAR_OUT
        BEQ NEWLINE
        CMP #$7E
        BEQ PUTCH_NL_COL1
        CMP #$7D
        BNE PUTCH_RTS
PUTCH_NL_COND
        LDA MON_CH
        CMP #$02
        BCC CURSOR_COL1
PUTCH_NL_COL1
        JSR NEWLINE
CURSOR_COL1                             ; (entry: column 1, no
        LDA #$01                        ;   newline -- overlays
        STA MON_CH                      ;   call it directly)
        RTS
NEWLINE_ALT
        ; newline after blanking the rest of the current row
        JSR CLR_EOL
NEWLINE
        SUBROUTINE
        ; Advance to the next line, scrolling the window if needed.
        ;
        ; Behavior:
        ;   INC MON_CV; past MON_WNDBTM, TEXT_SCROLL (X/Y saved).
        ;   Falls into CR.
        INC MON_CV
        LDA MON_CV
        CMP MON_WNDBTM
        BCC CR
        TYA
        PHA
        TXA
        PHA
        JSR TEXT_SCROLL
        PLA
        TAX
        PLA
        TAY
CR
        ; return the cursor to the left edge
        LDA #$00
        STA MON_CH
        RTS
WIN_SHRINK
        SUBROUTINE
        ; Shrink the text window by one on every side and home the
        ; cursor.
        ;
        ; Behavior:
        ;   top+1, bottom-1, left+1, width-2; MON_CV <- new top;
        ;   exits through CR (branch always taken).
        INC MON_WNDTOP
        DEC MON_WNDBTM
        INC MON_WNDLFT
        DEC MON_WNDWDTH
        DEC MON_WNDWDTH
        LDA MON_WNDTOP
        STA MON_CV
        BNE CR                          ; always (top is nonzero)
STR_NTH_CAP
        SUBROUTINE
        ; Print the Xth string from a packed table, capitalized.
        ;
        ; Inputs (inline): pointer to a packed string table (the
        ;   last character of each string has its high bit set).
        ;   X - string index (STR_FIRST prints entry 0)
        ;
        ; Behavior:
        ;   Set CAP_FLAG so the first lowercase letter is upcased,
        ;   then join STR_NTH: capture the table pointer, skip X
        ;   strings, print until a high-bit character.
        SEC
        ROR CAP_FLAG
        DC.B $2C                        ; BIT abs: skip the LDX
STR_FIRST
        LDX #$00
STR_NTH
        PLA
        STA MSG_PTR
        PLA
        STA MSG_PTR+1
        JSR MSG_GETC                    ; inline word -> table pointer
        STA STR_PTR
        JSR MSG_GETC
        STA STR_PTR+1
        LDA MSG_PTR+1                   ; return past the inline word
        PHA
        LDA MSG_PTR
        PHA
        TXA
        BEQ .print
.skip   JSR STR_GETC                    ; skip X strings
        ASL                             ; high bit ends a string
        BCC .skip
        DEX
        BNE .skip
.print  JSR STR_GETC
        CMP #$7F
        BEQ .tab
        PHA
        BIT CAP_FLAG
        BPL .emit
        AND #$7F
        CMP #$7C                        ; never fold control codes
        BCS .emit
        CMP #$61
        BCC .mark
        CMP #$7B
        BCS .mark
        EOR #$20                        ; capitalize the first letter
.mark   STA CAP_FLAG                    ; flag drops to a plain char
.emit   JSR PUTCH
        PLA
        BPL .print                      ; high bit set = last char
        LSR CAP_FLAG
        RTS
.tab    JSR STR_GETC                    ; tab: add operand to column
        CLC
        ADC MON_CH
        STA MON_CH
        JMP .print
MSG_AT
        ; position the cursor, then print the inline message
        STX MON_CH
        STY MON_CV
MSG_PRINT
        SUBROUTINE
        ; Print the zero-terminated text that follows the JSR.
        ;
        ; Behavior:
        ;   Pop the return address into MSG_PTR; PUTCH each byte
        ;   ($7F = tab: next byte adds to the column) until $00;
        ;   return past the terminator.
        PLA
        STA MSG_PTR
        PLA
        STA MSG_PTR+1
.next   JSR MSG_GETC
        BEQ .done
        CMP #$7F
        BEQ .tab
        JSR PUTCH
        JMP .next
.tab    JSR MSG_GETC
        CLC
        ADC MON_CH
        STA MON_CH
        JMP .next
.done   LDA MSG_PTR+1                   ; return past the terminator
        PHA
        LDA MSG_PTR
        PHA
        RTS
@ %def MSG_GETC STR_GETC MSG_PTR STR_PTR PRINT_HEX PRINT_DIGIT CHAR_OUT
@ %def PUTCH_RTS PUTCH PUTCH_NL_COND PUTCH_NL_COL1 CURSOR_COL1
@ %def NEWLINE_ALT NEWLINE CR
@ %def WIN_SHRINK STR_NTH_CAP
@ %def STR_FIRST STR_NTH MSG_AT MSG_PRINT

\section{Screen layout: the frame}

The game screen is built from the font's terrain-strip glyphs:
a bordered viewport (text rows 0--18), a horizontal divider, and
below it the message area and stats panel separated by a vertical
divider at column 30. [[DRAW_SCREEN]] clears the screen first;
[[DRAW_BORDERS]] redraws the frame alone (the engine calls it after
tearing down popup windows). [[CHAR_REPEAT]] is the brush: print
character A, X times, through the engine's [[CHAR_OUT]] (which
advances the cursor).

<<miu1 engine defines>>=
KBDSTRB         EQU $C010       ; clear keyboard strobe
TXTPAGE1        EQU $C054       ; display page 1
TXTPAGE2        EQU $C055       ; display page 2
HGR2            EQU $4000       ; hi-res page 2
MLIB_BLOAD      EQU $B703       ; file library: BLOAD, inline path
MLIB_PARSE_PATH_P EQU $B736     ; file library: parse path pointer
ZP_PX           EQU $06         ; STUPH: pixel column (PLOT/LINE)
ZP_PY           EQU $07         ; STUPH: pixel row
ZP_HGR_PTR      EQU $26         ; STUPH: screen pointer
ZP_PAGE_TGL     EQU $80         ; STUPH: page-flip toggle mask
; --- STUPH zero page and tables shared by the engine ---
ZP_TXT_PTR      EQU $28         ; scanline pointer (CURSOR_TO_TEXT)
ZP_BCD          EQU $62         ; BIN2BCD: 6-digit BCD result (3 bytes)
ZP_BIN          EQU $65         ; BIN2BCD: 16-bit input (2 bytes)
ZP_RND_TMP      EQU $69         ; RND_MOD: limit, then result
ZP_SFX_CNT      EQU $7D         ; STUPH: pending effect count
ZP_INVERSE      EQU $7E         ; STUPH: video EOR mask ($7F = inverse)
ZP_PAGE_XOR     EQU $7F         ; STUPH: draw page selector
