\centering
\caption{The resident memory map during play. Addresses below
  [[OVERLAY_ENTRY]] persist across mode changes; the overlay region is
  reloaded on every switch.}
\label{tab:memmap-arch}
\begin{tabular}{lll}
\toprule
Region & Contents & Lifetime \\
\midrule
[[$0800]]--[[$1FFF]] & \texttt{STUPH} resident library + glyph banks & whole session \\
[[$2000]]--[[$5FFF]] & hi-res pages 1 and 2 (double-buffered display) & whole session \\
