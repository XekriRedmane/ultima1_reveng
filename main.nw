<<spa fixed math>>=
        ORG $A107
MUL8_FIXED
        SUBROUTINE
        ; Fixed-point multiply and divide for the projection.
        ;
        ; Behavior:
        ;   MUL8_FIXED multiplies A by ZP_MUL_B into a 16-bit product; DIV16
        ;   divides the 16-bit ZP_FX2 by ZP_FX0.  Together they rotate and scale
        ;   the enemy position into the front view.
        ;
        ; Clobbers: A, X
        PHP
        CLD
        STA ZP_FX0
        LDA #$08
        STA ZP_FX_CNT
        LDA #$00
        STA ZP_FX2
.LA113
        LSR ZP_FX0
        BCC .LA11A
        CLC
        ADC ZP_MUL_B
.LA11A
        ROR
        ROR ZP_FX2
        DEC ZP_FX_CNT
        BNE .LA113
        PLP
        RTS
DIV16
        STA ZP_FX1
        PHP
        CLD
        LDA #$10
        STA ZP_FX_CNT
        LDA #$00
        STA ZP_FX4
        STA ZP_FX5
.LA131
        ASL ZP_FX2
        ROL ZP_FX3
        ROL ZP_FX4
        ROL ZP_FX5
        LDA ZP_FX4
        SEC
        SBC ZP_FX0
        STA ZP_FX_T
        LDA ZP_FX5
        SBC ZP_FX1
        BCC .LA14E
        INC ZP_FX2
        STA ZP_FX5
        LDA ZP_FX_T
        STA ZP_FX4
.LA14E
        DEC ZP_FX_CNT
        BNE .LA131
        PLP
        RTS
@

<<spa fuel burn>>=
        ORG $A154
FUEL_BURN
        SUBROUTINE
        ; Subtract a fuel cost, clamping at empty.
        ;
        ; Behavior:
        ;   FUEL_BURN takes A units off the 16-bit PLR_FUEL, clamping at zero and
        ;   clearing the rotation timer when the tank runs dry, then falls into
        ;   the status redraw.
        ;
        ; Modifies: PLR_FUEL
        ; Clobbers: A
        STA ZP_T0
        SEC
        LDA PLR_FUEL
        SBC ZP_T0
        STA PLR_FUEL
        BCS .LA175
        DEC PLR_FUEL+1
        LDA PLR_FUEL+1
        CMP #$FF
        BNE WIN_STATS_DRAW
        LDA #$00
        STA PLR_FUEL
        STA PLR_FUEL+1
        BEQ .LA17F
.LA175
        LDA PLR_FUEL
        ORA PLR_FUEL+1
        BNE WIN_STATS_DRAW
        LDA #$00
.LA17F
        STA ROT_TIMER
@

<<spa stats panel>>=
        ORG $A182
WIN_STATS_DRAW
        SUBROUTINE
        ; Draw the Shld | Fuel | Exp | Coin status panel.
        ;
        ; Behavior:
        ;   Print the four 16-bit ship/player figures into the stats window,
        ;   each via PRINT_STAT16 (which highlights low values), then restore.
        ;
        ; Clobbers: A, X, Y
        JSR WIN_SAVE
        JSR WIN_STATS
        STA NUM_PAD
        LDA #$24
        STA MON_WNDLFT
        LDA #$04
        STA MON_WNDWDTH
        LDA PLR_SHIELD+1
        LDX PLR_SHIELD
        JSR PRINT_STAT16
        LDA PLR_FUEL+1
        LDX PLR_FUEL
        JSR PRINT_STAT16
        LDA PLR_EXP+1
        LDX PLR_EXP
        JSR PRINT_STAT16
        LDA PLR_COIN+1
        LDX PLR_COIN
        JSR PRINT_NUM16
        JSR CLR_EOL
        JMP WIN_RESTORE
@

<<spa spend turn>>=
        ORG $A1BD
SPEND_TURN
        SUBROUTINE
        ; Spend a game turn at a fixed time cost.
        ;
        ; Behavior:
        ;   Preserve the registers and call the engine TICK with a fixed move
        ;   count, so a space action advances the world clock.
        ;
        ; Clobbers: nothing (registers preserved)
        PHA
        TXA
        PHA
        TYA
        PHA
        LDY #$00
        LDA #$05
        JSR TICK
        PLA
        TAY
        PLA
        TAX
        PLA
        RTS
@

