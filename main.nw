        CPX #$FF
        BEQ .L9EF4
        LDA PRICE
        CLC
        ADC ZP_T0
        STA PRICE
        LDA PRICE+1
        ADC #$00
        STA PRICE+1
        JMP .L9EDB
.L9EF4
        RTS
