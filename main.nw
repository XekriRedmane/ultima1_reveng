        ;   Each digit multiplies AMOUNT by ten (x8 + x2 via shifts) and
        ;   adds the digit.  Up to four digits.  Return on RETURN.
        ;
        ; Outputs:  AMOUNT = entered value (16-bit)
        ; Clobbers: A, X, Y
        LDA #$00
        STA AMOUNT
        STA AMOUNT+1
        STA PENCE_HALF
        STA PENCE_HALF+1
        STA NUM_DIGITS
.L9C5B
