LINE_TO         EQU $15DA       ; line to (X,Y)
LINE_AGAIN      EQU $15DD       ; line to previous destination
SOUND_SET       EQU $15E0       ; master sound off/on (A = 0/1)
ACCEL_NUDGE     EQU $15E3       ; slow accelerators (sound off)
FRAME_SYNC      EQU $15E6       ; wait for vertical blank
