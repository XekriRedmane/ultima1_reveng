        STY CURSOR_IDX
        JSR EDITOR_DRAW
        JSR CLEAR_LINES
        LDY #$12
        LDX #$0B
        JSR MSG_AT
        DC.B "a) Human|",$7F,$0B,"b) Elf|",$7F,$0B,"c) Dwarf|",$7F,$0B,"d) Bobbit",0
        LDY #$10
        LDX #$02
        JSR MSG_AT
        DC.B "Select thy race: ",0
.L8CD0
        JSR KEY_WAIT
        CMP #$41
        BCC .L8CD0
        CMP #$45
        BCS .L8CD0
        SEC
        SBC #$40
        STA PLR_RACE
        LDY #$0C
        LDX #$0D
        JSR MSG_AT
        DC.B "Race  ",0
        LDX PLR_RACE
        JSR STR_NTH_CAP
