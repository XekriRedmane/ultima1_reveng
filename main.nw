        LDY ZP_PTR+1
        LDA CELL_COL,Y
        CLC
        ADC ZP_PTR
        TAY
        LDA #$00
        STA CELL_STATE,Y
        RTS
DRAW_MONDAIN
        LDA CRAFT_GFX+6
        LDY TGT_X
        LDX TGT_Y
        JSR PROJECT_XY
        LDX CRAFT_GFX+6
        LDA #$00
        LDY #$01
        JSR PLOT_VERTEX2
        LDA #$01
        LDY CRAFT_GFX+6
        JSR PLACE_SHAPE
