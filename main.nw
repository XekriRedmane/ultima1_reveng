        LDA #$C8
        SEC
        SBC PLR_INT
        LSR
        LSR
        STA ZP_T0
        JMP PRICE_MUL
PRICE_WEAPON
        LDA #$FF
        SEC
        SBC PLR_INT
        STA ZP_T0
        LDA ITEM_COST,X
        TAX
        JSR PRICE_MUL
        LDA PRICE+1
        CLC
        ADC #$05
        STA PRICE
        LDA #$00
        STA PRICE+1
        RTS
PRICE_TRANSPORT
        LDA #$C8
        SEC
        SBC PLR_INT
        LDY #$00
.L9EC7
        INY
        SEC
        SBC #$05
        BCS .L9EC7
        STY ZP_T0
        LDA ITEM_COST,X
        TAX
PRICE_MUL
        LDA #$00
        STA PRICE
        STA PRICE+1
.L9EDB
