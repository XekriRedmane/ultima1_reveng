        BCC .L9BDF
        CMP #$47
        BCS .L9BDF
        SEC
        SBC #$40
        TAX
        LDA BUY_AVAIL,X
        BNE .L9BE2
.L9BDF
        JMP SHOP_NOTHING
.L9BE2
        STX ZP_T1
        JSR PRICE_TRANSPORT
        JSR SHOP_CANAFFORD
        BCS .L9BEF
        JMP SHOP_REFUSE
.L9BEF
        LDX ZP_T1
        INC OWNED_TRANSPORT,X
        CPX #$06
        BNE .L9C08
        LDA #$E8
        STA SHUTTLE_GEMS
        STA SHUTTLE_GEMS+2
        LDA #$03
        STA SHUTTLE_GEMS+1
        STA SHUTTLE_GEMS+3
.L9C08
        LDA TRANSPORT_TERRAIN,X
        LDY #$03
.L9C0D
        CMP COURT_CELLS,Y
        BEQ .L9C25
        CPX #$03
        BCS .L9C21
        STA ZP_T0
        LDA COURT_CELLS,Y
        CMP #$02
        BEQ .L9C25
        LDA ZP_T0
.L9C21
        DEY
        BPL .L9C0D
        INY
.L9C25
        TXA
        CLC
        ADC #$08
        STA COURT_CELLS,Y
        JSR SHOP_DEBIT
        JSR WIN_TEXT
        LDA #$17
        STA MON_CV
        LDA #$0F
        STA MON_CH
        LDX ZP_T1
        JSR STR_NTH
        DC.W STR_TRANSPORT
        JMP FLUSH_KEYS
TRANSPORT_PRICE
