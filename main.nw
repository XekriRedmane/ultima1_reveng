        RTS
SHOP_DONE
        JSR CLEAR_MSGS
        JSR MSG_PRINT
        DC.B $7F,$0B,"Done!",0
        RTS
SHOP_TOOPOOR
        JSR CLEAR_MSGS
        JSR MSG_PRINT
        DC.B "  Thou canst not afford it!   ",0
        JSR BEEP_HUH
        JMP FLUSH_KEYS
PRICE_BY_WIS
        LDA #$C8
        SEC
        SBC PLR_WIS
        LSR
        LSR
        LSR
        LSR
        LSR
        STA ZP_T0
        JMP PRICE_MUL
