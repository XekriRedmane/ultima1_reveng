[[DRAW_AHEAD_WALL]] draws the face straight ahead --- the end of
the corridor, or the visible face of a door/secret/field cell ---
and joins it to the previous slice's side walls so the tunnel
reads as continuous.

<<dng primitive ahead wall>>=
        ORG $A2AF
DRAW_AHEAD_WALL
        SUBROUTINE
        ; Draw the cell-ahead face and connect it to the last slice.
        ;
        ; Behavior:
        ;   Stroke the rectangular face that closes the corridor
        ;   straight ahead, then add ceiling/floor connectors back to
        ;   whichever side walls the previous slice drew, so the
        ;   tunnel reads as one continuous surface.
        ; Clobbers: A, X, Y
        LDX VIEW_DEPTH
        LDA DNG_GEOM,X
        STA $06
        LDA DNG_GEOM+$16,X
        STA $07
        STA $09
        LDA DNG_GEOM+$0B,X
        STA $08
        JSR LINE_AGAIN
        LDX VIEW_DEPTH
        LDA DNG_GEOM+$0C,X
        STA $08
        LDA DNG_GEOM+$21,X
        STA $07
        STA $09
        JSR LINE_AGAIN
        LDX VIEW_DEPTH
        LDA DNG_GEOM,X
        STA $06
        LDA DNG_GEOM+$01,X
        STA $08
        JSR LINE_AGAIN
        LDA VIEW_CELL                   ; a door at depth 0 needs no
        CMP #$04                        ;   ceiling diagonal
        BNE .ceil
        LDX VIEW_DEPTH
        BEQ .left_prev
.ceil   LDX VIEW_DEPTH
        LDA DNG_GEOM+$0C,X
        STA $08
        JSR LINE_AGAIN
.left_prev
        LDA VIEW_L_PREV                 ; join to the previous left
        CMP #$01                        ;   wall if it was solid
        BEQ .join_l
        CMP #$03
        BEQ .join_l
        CMP #$04
        BNE .right_prev
.join_l LDX VIEW_DEPTH
        LDA DNG_GEOM+$16,X
        STA $09
        LDA DNG_GEOM,X
        STA $06
        STA $08
        JSR LINE_AGAIN
.right_prev
        LDA VIEW_R_PREV                 ; ...and the previous right
        CMP #$01
        BEQ .join_r
        CMP #$03
        BEQ .join_r
        CMP #$04
        BNE .done
.join_r LDX VIEW_DEPTH
        LDA DNG_GEOM+$0B,X
        STA $06
        STA $08
        LDA DNG_GEOM+$16,X
        STA $07
        LDA DNG_GEOM+$21,X
        STA $09
        JSR LINE_AGAIN
.done   RTS
@ %def DRAW_AHEAD_WALL

[[DRAW_AHEAD_OPEN]] draws the opening through a doorway in the
cell straight ahead: the doorframe rectangle the player will walk
through.

<<dng primitive ahead open>>=
        ORG $A347
DRAW_AHEAD_OPEN
        SUBROUTINE
        ; Draw the doorway opening in the cell straight ahead.
        ;
        ; Behavior:
        ;   Skip if a monster blocks it. Otherwise stroke the inner
        ;   rectangle of the doorframe the player will walk through.
        ; Clobbers: A, X, Y
        LDX VIEW_DEPTH
        LDA MON_SLOT                    ; skip if a monster blocks it
        BEQ .draw
        CLC
        ADC MON_BASE
        CMP #$1E
        BEQ .draw
        CMP #$20
        BEQ .draw
        CMP #$29
        BEQ .draw
        RTS
.draw   LDA DNG_GEOM+$01,X
        STA $06
        STA $08
        LDA DNG_GEOM+$21,X
        STA $07
        LDA DNG_GEOM+$17,X
        STA $09
        JSR LINE_AGAIN
        LDX VIEW_DEPTH
        LDA DNG_GEOM+$0C,X
        STA $08
        JSR LINE_AGAIN
        LDX VIEW_DEPTH
        LDA DNG_GEOM+$21,X
        STA $09
        JMP LINE_AGAIN
@ %def DRAW_AHEAD_OPEN

