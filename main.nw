<<spa preshift>>=
        ORG $9F2E
SHAPE_PRESHIFT
        SUBROUTINE
        ; Pre-shift a shape into hi-res byte alignment.
        ;
        ; Behavior:
        ;   Rotate each row of the shape buffer right by the column's sub-byte
        ;   pixel offset (preserving the high artifact bit), producing the byte-
        ;   aligned copy the blitter ORs onto the screen.
        ;
        ; Clobbers: A, X, Y
        STA SHIFT_SCRATCH
        STX ZP_SHIFT_CNT
        LDA ZP_SHP_SRC
        STA ZP_SHP_DST
        LDA ZP_SHP_SRC+1
        STA ZP_SHP_DST+1
.L9F3B
        CLC
        LDA ZP_SHP_DST
        ADC SHIFT_SCRATCH
        STA ZP_SHP_DST
        BCC .L9F47
        INC ZP_SHP_DST+1
.L9F47
        DEX
        BNE .L9F3B
        LDA #$06
        STA SHIFT_SCRATCH+1
        LDY #$00
.L9F51
        LDA SHIFT_SCRATCH
        STA ZP_SHIFT_ROW
.L9F56
        CLC
        LDX ZP_SHIFT_CNT
.L9F59
        LDA (ZP_SHP_SRC),Y
        ROL
        CLC
        BPL .L9F60
        SEC
.L9F60
        AND #$7F
        STA (ZP_SHP_DST),Y
        INC ZP_SHP_SRC
        BNE .L9F6A
        INC ZP_SHP_SRC+1
.L9F6A
        INC ZP_SHP_DST
        BNE .L9F70
        INC ZP_SHP_DST+1
.L9F70
        DEX
        BNE .L9F59
        DEC ZP_SHIFT_ROW
        BNE .L9F56
        DEC SHIFT_SCRATCH+1
        BNE .L9F51
        RTS
@

