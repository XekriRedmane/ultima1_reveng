<<miu1 char repeat>>=
        ORG $8144
CHAR_REPEAT
        SUBROUTINE
        ; Print character A, X times.
        ;
        ; Behavior:
        ;   X (>= 1) copies of character A through CHAR_OUT, which
        ;   advances the cursor and handles the layout codes.
.rep    JSR CHAR_OUT
        DEX
        BNE .rep
        RTS
@ %def CHAR_REPEAT

<<miu1 screen frame>>=
        ORG $814B
DRAW_SCREEN
        SUBROUTINE
        ; Draw the standard game screen.
        ;
        ; Behavior:
        ;   DRAW_SCREEN clears the whole screen first; DRAW_BORDERS
        ;   only redraws the frame. Top border (glyphs $10/$04/$12),
        ;   side strips ($0A left, $08 right) down to row $12, the
        ;   horizontal divider ($04/$06), and the vertical divider
        ;   (glyphs $02/$0C) at column 30 between the message area
        ;   and the stats panel.
        ;
        ; Clobbers: A, X
        JSR WIN_FULL
        JSR CLR_WINDOW
DRAW_BORDERS
        JSR WIN_FULL
        LDA #$10                        ; top-left corner strip
        JSR CHAR_OUT
        LDX #$26
        LDA #$04                        ; horizontal border strip
        JSR CHAR_REPEAT
        LDA #$12                        ; top-right corner strip
        JSR FONT_DRAW
.side   INC MON_CV
        JSR CR
        LDA #$0A                        ; left edge
        JSR FONT_DRAW
        LDA #$27
        STA MON_CH
        LDA #$08                        ; right edge
        JSR FONT_DRAW
        JSR KEY_POLL                    ; keep type-ahead fresh
        LDA MON_CV
        EOR #$12                        ; down to row 18
        BNE .side
        STA MON_CH                      ; column 0
        INC MON_CV
        LDA #$04
        JSR CHAR_OUT
        LDX #$26
        LDA #$06                        ; the viewport/text divider
        JSR CHAR_REPEAT
        LDA #$04
        JSR FONT_DRAW
        LDA #$1E
        STA MON_CH                      ; column 30:
        LDA #$02                        ;   divider top piece
        JSR FONT_DRAW
        LDA #$0C                        ;   divider body
.vert   INC MON_CV
        JSR FONT_DRAW
        LDX MON_CV
        CPX #$17
        BCC .vert
        RTS
@ %def DRAW_SCREEN DRAW_BORDERS

\section{Numbers: binary to BCD, decimal printing}

The player's stats are kept in 16-bit \emph{binary}; only the
display converts. [[BIN2BCD]] is the classical double-dabble:
shift the binary value right a bit at a time and, for each 1 bit,
add the corresponding power of two --- maintained in BCD in
[[BCD_POW]] by doubling it in decimal mode each round --- into the
6-digit accumulator at [[ZP_BCD]].

[[PRINT_NUM16]] prints X/A (lo/hi) in decimal --- up to six digits
--- and [[PRINT_NUM8]] prints A (up to four digits, of which at
most three can be nonzero). Leading zeros are suppressed through
[[NUM_ZSTATE]]; if [[NUM_PAD]] is nonzero they are instead replaced
by that pad character (the status panel sets a pad to keep its
columns aligned, see below). The ones digit always prints, even
for the value zero.

<<miu1 bin2bcd>>=
        ORG $81AD
BIN2BCD SUBROUTINE
        ; Convert the 16-bit binary value X/A (lo/hi) to six BCD
        ; digits in ZP_BCD.
        ;
        ; Inputs:
        ;   X, A    -- value low/high byte
        ;
        ; Behavior:
        ;   Double-dabble: for each set bit of the value (tested
        ;   low to high), add BCD_POW (the bit's power of two, kept
        ;   in BCD) into ZP_BCD in decimal mode; double BCD_POW
        ;   each round.
        ;
        ; Outputs:
        ;   ZP_BCD..+2 = BCD digits, least significant byte first.
        ;
        ; Modifies:
        ;   ZP_BIN, BCD_POW
        ; Clobbers: A (X = 1 on return)
        STX ZP_BIN
        STA ZP_BIN+1
        LDX #$00
        STX ZP_BCD
        STX ZP_BCD+1
        STX ZP_BCD+2
        STX BCD_POW+2
        STX BCD_POW+1
        INX
        STX BCD_POW                     ; BCD_POW <- #$000001
        SED
.bit    LSR ZP_BIN+1
        ROR ZP_BIN
        BCC .dbl
        CLC
        LDA ZP_BCD
        ADC BCD_POW
        STA ZP_BCD
        LDA ZP_BCD+1
        ADC BCD_POW+1
        STA ZP_BCD+1
        LDA ZP_BCD+2
        ADC BCD_POW+2
        STA ZP_BCD+2
.dbl    CLC
        LDA BCD_POW
        ADC BCD_POW
        STA BCD_POW
        LDA BCD_POW+1
        ADC BCD_POW+1
        STA BCD_POW+1
        LDA BCD_POW+2
        ADC BCD_POW+2
        STA BCD_POW+2
        LDA ZP_BIN
        ORA ZP_BIN+1
        BNE .bit
        CLD
        RTS
BCD_POW HEX 01 00 00                    ; the running power, in BCD
@ %def BIN2BCD BCD_POW

<<miu1 print numbers>>=
        ORG $8207
PRINT_NUM16
        SUBROUTINE
        ; Print X/A (lo/hi) in decimal; PRINT_NUM8 prints just A.
        ;
        ; Inputs:
        ;   X, A    -- the value (PRINT_NUM8: A only)
        ;   NUM_PAD -- 0 to suppress leading zeros, else the pad
        ;              character to print in their place
        ;
        ; Behavior:
        ;   BIN2BCD, then emit digits high to low through DIGIT_OUT
        ;   (6 digits for NUM16, 4 for NUM8). NUM_ZSTATE tracks
        ;   whether a significant digit has appeared; the final
        ;   ones digit is forced significant.
        ;
        ; Modifies:
        ;   ZP_BCD, ZP_BIN, BCD_POW, NUM_ZSTATE
        ; Clobbers: A, X
        JSR BIN2BCD
        INX                             ; X <- #$02: 3 BCD bytes
        BNE .start                      ; (always)
PRINT_NUM8
        TAX
        LDA #$00
        JSR BIN2BCD                     ; X = 1 after: 2 BCD bytes
.start  STA NUM_ZSTATE                  ; NUM_ZSTATE <- #$00
        JMP .lowq
.hi     LDA ZP_BCD,X                    ; high nibble first
        LSR
        LSR
        LSR
        LSR
        JSR DIGIT_OUT
.lowq   TXA
        BNE .lo
        INC NUM_ZSTATE                  ; the ones digit always shows
.lo     LDA ZP_BCD,X
        JSR DIGIT_OUT
        DEX
        BPL .hi
.rts    RTS
DIGIT_OUT
        ; Print BCD digit (low nibble of A), with leading-zero
        ; suppression or padding.
        AND #$0F
        BNE .sig
        CMP NUM_ZSTATE                  ; still in leading zeros?
        BNE .show
        LDA NUM_PAD
        BEQ .rts
        JMP CHAR_OUT                    ; print the pad character
.sig    STA NUM_ZSTATE                  ; significant from here on
.show   JMP PRINT_DIGIT
NUM_ZSTATE
        DC.B $00                        ; nonzero once a digit shown
NUM_PAD DC.B $00                        ; leading-zero pad character
@ %def PRINT_NUM16 PRINT_NUM8 DIGIT_OUT NUM_ZSTATE NUM_PAD

<<miu1 div10>>=
        ORG $824A
DIV10   SUBROUTINE
        ; A := A / 10.
        ;
        ; Behavior:
        ;   Repeated subtraction; Y counts the quotient. The
        ;   remainder is discarded.
        LDY #$FF
        SEC
.sub    INY
        SBC #$0A
        BCS .sub
        TYA
        RTS
@ %def DIV10

\section{Random numbers and pacing}

[[RND_MOD]] is the game's dice: a random number 0..A-1, reduced
from the library's [[RND]] stream by repeated subtraction.
[[KEY_PENDING]] samples the keyboard and returns the type-ahead
count; [[PAUSE_ABORTABLE]] is the ``dramatic pause'' --- about 61
delay units, abandoned the moment the player presses a key.

<<miu1 rnd mod>>=
        ORG $8254
RND_MOD SUBROUTINE
        ; A := random number in 0..A-1 (flags reflect the result).
        ;
        ; Inputs:
        ;   A       -- the limit
        ;
        ; Behavior:
        ;   Draw a byte from RND and reduce it modulo the limit by
        ;   repeated subtraction.
        ;
        ; Outputs:
        ;   A and ZP_RND_TMP = the result; Z/N set per the value.
        STA ZP_RND_TMP
        JSR RND
.mod    CMP ZP_RND_TMP
        BCC .done
        SBC ZP_RND_TMP
        BCS .mod
.done   CMP #$00                        ; result flags for the caller
        STA ZP_RND_TMP
        RTS
@ %def RND_MOD

<<miu1 key pending>>=
        ORG $8266
KEY_PENDING
        SUBROUTINE
        ; Sample the keyboard; A := type-ahead count (Z = no key).
        ;
        ; Behavior:
        ;   KEY_POLL once, then return ZP_KEY_CNT so callers can
        ;   loop on BNE/BEQ.
        JSR KEY_POLL
        LDA ZP_KEY_CNT
        RTS
PAUSE_ABORTABLE
        ; Pause for effect: ~61 delay units, cut short by any key.
        JSR KBD_CLEAR
        LDY #$3D
.wait   JSR KEY_PENDING
        BNE .rts
        JSR VDELAY
        DEY
        BNE .wait
.rts    RTS
@ %def KEY_PENDING PAUSE_ABORTABLE

\section{Command input}

Movement uses the Apple's arrow keys --- left [[$08]], right
[[$15]], up [[$0B]], down [[$0A]] --- but a ][+ has only left and
right, so [[KEY_ALIAS]] folds nearby keys onto the missing arrows:
\emph{Return} and \texttt{[} act as up, \texttt{/} as down, and
\texttt{'} and \texttt{;}/\emph{Delete} as right and left
(the right-hand home-row cluster).

[[GET_COMMAND]] turns a keypress into a command number: the aliased
key is looked up in the 26-entry [[CMD_KEYS]] table; a miss prints
\emph{Huh?} with the error blat and returns carry set. A hit echoes
the command's name from the [[STR_COMMANDS]] table --- with a twist
for the four movement commands (indexes 0--3): when [[DIR_STR_PTR]]
is nonzero the overlay has installed its own direction-name table
(``Head West'' outdoors, but space flight needs other words), and
the echo reads from it instead. Returns carry clear and X = twice
the command index, ready for an overlay's address-table dispatch.

<<miu1 key alias>>=
        ORG $827D
KEY_ALIAS
        SUBROUTINE
        ; Fold the movement-key aliases onto the arrow codes.
        ;
        ; Inputs:
        ;   A       -- key from KEY_GET
        ;
        ; Behavior:
        ;   Compare against the six alias keys; matches return the
        ;   corresponding arrow code, anything else passes through.
        ;
        ; Outputs:
        ;   A -- arrow code if aliased (CR,[ -> $0B up; / -> $0A
        ;   down; ' -> $15 right; ;,DEL -> $08 left), else as given.
        CMP #$0D
        BEQ .up
        CMP #$5B
        BEQ .up
        CMP #$2F
        BEQ .down
        CMP #$27
        BEQ .right
        CMP #$3B
        BEQ .left
        CMP #$7F
        BEQ .left
        RTS
.up     LDA #$0B
        RTS
.down   LDA #$0A
        RTS
.right  LDA #$15
        RTS
.left   LDA #$08
        RTS
@ %def KEY_ALIAS

<<miu1 get command>>=
        ORG $82A2
GET_COMMAND
        SUBROUTINE
        ; Translate key A into a command number and echo its name.
        ;
        ; Inputs:
        ;   A           -- key; CMD_KEYS -- the 26 command keys
        ;   DIR_STR_PTR -- overlay's direction-name table, or 0
        ;
        ; Behavior:
        ;   Alias arrows, then search CMD_KEYS. On a miss: print
        ;   "Huh?", blat, return C set. On a hit: print the name
        ;   (movement commands 0-3 use the overlay's table when
        ;   installed), return C clear, X = 2 * index.
        ;
        ; Outputs:
        ;   C set = unknown key; else X = command index * 2.
        JSR KEY_ALIAS
        LDX #$19
.find   CMP CMD_KEYS,X
        BEQ .hit
        DEX
        BPL .find
        JSR MSG_PRINT
        DC.B "Huh?",$00
        JSR BEEP_HUH
        SEC
        RTS
.hit    TXA
        PHA
        CMP #$04                        ; a movement command?
        BCS .name
        LDA DIR_STR_PTR+1
        BEQ .name                       ; no overlay table installed
        STA .dir+1
        LDA DIR_STR_PTR
        STA .dir
        JSR STR_NTH
.dir    DC.W STR_COMMANDS               ; (patched: overlay's table)
        JMP .done
.name   JSR STR_NTH
        DC.W STR_COMMANDS
.done   PLA
        ASL
        TAX
        CLC
        RTS
@ %def GET_COMMAND

\section{The cost of a turn}

Every turn costs food and advances the move counter, and that
arithmetic lives in one dual-entry routine. [[TICK]] is the silent
entry; [[TICK_SND]] additionally queues effect 0, the per-turn
move thump (the outdoor overlay charges every turn through this
entry). Y is the food cost in BCD \emph{hundredths} (the visible
food number only drops when [[FOOD_FRAC]] borrows), and A is added
to the multi-byte BCD [[MOVE_CNT]]. Food clamps at zero --- starvation's
consequences are the overlays' business.

<<miu1 tick>>=
        ORG $82E2
TICK    SUBROUTINE
        ; Charge a turn: food -= Y/100, moves += A.
        ;
        ; Inputs:
        ;   Y       -- food cost, BCD hundredths
        ;   A       -- move-counter increment (BCD)
        ;
        ; Behavior:
        ;   TICK_SND also queues sound effect 0 -- the per-turn
        ;   move thump (the OUT overlay uses it for every turn).
        ;   Subtract from FOOD_FRAC; on borrow, decrement the
        ;   16-bit binary PLR_FOOD, clamping at zero. Add A into
        ;   the multi-byte BCD MOVE_CNT with carry propagation.
        ;
        ; Modifies:
        ;   TICK_FOOD, TICK_MOVE, FOOD_FRAC, PLR_FOOD, MOVE_CNT
        ; Clobbers: A, X
        CLC                             ; silent entry
        DC.B $B0                        ; BCS: never taken; its
                                        ;   operand is the SEC below
TICK_SND
        SEC                             ; sound entry ($38 doubles
                                        ;   as the BCS operand)
        STY TICK_FOOD
        STA TICK_MOVE
        BCC .food
        LDA #$00                        ; queue the move thump
        JSR SFX_QUEUE
.food   SED
        SEC
        LDA FOOD_FRAC
        SBC TICK_FOOD
        STA FOOD_FRAC
        BCS .moves
        LDA PLR_FOOD                    ; borrow: food -= 1
        ORA PLR_FOOD+1
        BEQ .moves                      ; already starving: clamp
        LDA PLR_FOOD
        BNE .declo
        DEC PLR_FOOD+1
.declo  DEC PLR_FOOD
.moves  CLC
        LDA MOVE_CNT
        ADC TICK_MOVE
        STA MOVE_CNT
        BCS .carry
        CLD
        RTS
.carry
MOVE_CNT_INC                            ; (entry: +1 whole move --
        SED                             ;   OUT charges each step
        SEC                             ;   on foot this way)
        LDX #$00
.prop   LDA MOVE_CNT+1,X
        ADC #$00
        STA MOVE_CNT+1,X
        INX
        BCS .prop
        CLD
        RTS
@ %def TICK TICK_SND MOVE_CNT_INC

\section{The stats panel}

The right-hand panel shows Hits, Food, Exp.\ and Coin.
[[STATS_DRAW]] paints labels and values; [[STATS_VALUES]] repaints
just the numbers (called after every change). Both work inside a
window save/restore pair --- [[WIN_SAVE]] and [[WIN_RESTORE]] copy
the six monitor window variables to [[WIN_SAVE_BUF]] and back, the
engine's standard idiom for drawing somewhere else and returning
(every popup in the game uses it). The values are right-aligned at
column 36, and Hits and Food below 100 print in \emph{inverse
video} ([[PRINT_STAT16]] sets [[ZP_INVERSE]]) --- the low-vitals
warning flash.

<<miu1 stats panel>>=
        ORG $8331
STATS_DRAW
        SUBROUTINE
        ; Repaint the stats panel, labels and values.
        ;
        ; Behavior:
        ;   Save the window; select the stats window; print the
        ;   four labels stacked (| = newline); join STATS_VALUES.
        ;
        ; Modifies:
        ;   WIN_SAVE_BUF, the monitor window variables
        ; Clobbers: A, X
        JSR WIN_SAVE
        JSR WIN_STATS
        JSR MSG_PRINT
        DC.B "Hits |Food |Exp. |Coin ",$00
        JMP STATS_JOIN
PRINT_STAT16
        ; Print X/A (lo/hi); values below 100 print in inverse
        ; video (the low-Hits/Food warning), then end the line.
        CMP #$01
        BCS .show
        CPX #$64
        BCS .show
        PHA
        LDA #$7F
        STA ZP_INVERSE                  ; inverse video on
        PLA
.show   JSR PRINT_NUM16
        JSR NEWLINE_ALT
        LDA #$00
        STA ZP_INVERSE
        RTS
STATS_VALUES
        ; Repaint only the four numbers, right-aligned at col 36.
        JSR WIN_SAVE
STATS_JOIN
        JSR WIN_STATS
        STA NUM_PAD                     ; NUM_PAD <- #$00 (A from
                                        ;   WIN_STATS): no padding
        LDA #$24
        STA MON_WNDLFT                  ; numbers column (36)
        LDA #$04
        STA MON_WNDWDTH
        LDA PLR_HITS+1
        LDX PLR_HITS
        JSR PRINT_STAT16
        LDA PLR_FOOD+1
        LDX PLR_FOOD
        JSR PRINT_STAT16
        LDA PLR_EXP+1
        LDX PLR_EXP
        JSR PRINT_NUM16
        JSR NEWLINE_ALT
        LDA PLR_COIN+1
        LDX PLR_COIN
        JSR PRINT_NUM16
        JSR CLR_EOL
        ; falls into WIN_RESTORE
WIN_RESTORE
        SUBROUTINE
        ; Restore the six window variables from WIN_SAVE_BUF.
        ;
        ; Behavior:
        ;   Copy WIN_SAVE_BUF back over MON_WNDLFT..MON_CV --
        ;   the closing half of the engine's draw-elsewhere idiom.
        LDX #$05
.cp     LDA WIN_SAVE_BUF,X
        STA MON_WNDLFT,X
        DEX
        BPL .cp
        RTS
WIN_SAVE
        SUBROUTINE
        ; Save the six window variables to WIN_SAVE_BUF.
        ;
        ; Behavior:
        ;   Copy MON_WNDLFT..MON_CV into WIN_SAVE_BUF before
        ;   drawing somewhere else; WIN_RESTORE undoes it.
        LDX #$05
.cp     LDA MON_WNDLFT,X
        STA WIN_SAVE_BUF,X
        DEX
        BPL .cp
        RTS
@ %def STATS_DRAW PRINT_STAT16 STATS_VALUES STATS_JOIN WIN_RESTORE
@ %def WIN_SAVE

\section{Feedback}

Small replies to the player. [[PRINT_SPELL]] names the readied
spell (the \emph{Cast} echo). [[CURSOR_TO_TEXT]]
backs the cursor up to just past the last drawn character ---
it walks a row's bottom scanline leftward through the hi-res
pointer until it finds ink --- so [[QUERY_MARK]] can append a
\texttt{?} right after whatever prompt is on screen.
[[NO_EFFECT_MSG]] is the spell-fizzle message; [[BEEP_HUH]] the
error blat. All of them end in [[KBD_CLEAR]], which flushes
\emph{both} queues --- a rejected or completed command should
neither replay buffered keys nor play stale sounds.

<<miu1 feedback>>=
        ORG $83BF
PRINT_SPELL
        SUBROUTINE
        ; Print the readied spell's name.
        ;
        ; Behavior:
        ;   STR_NTH from the spell-name table, indexed by
        ;   READY_SPELL. (The Ready command's argument layout
        ;   proves these tables out: spells are the 10-entry list.)
        LDX READY_SPELL
        JSR STR_NTH
        DC.W STR_SPELLS
        RTS
CURSOR_TO_TEXT
        SUBROUTINE
        ; Back MON_CH up to just past the last drawn character.
        ;
        ; Behavior:
        ;   Point ZP_TXT_PTR at the cursor row's bottom scanline
        ;   (the glyph baseline) on the draw page, then decrement
        ;   MON_CH past columns whose pixels are all clear.
        ;
        ; Modifies:
        ;   ZP_TXT_PTR, MON_CH
        LDA MON_CV
        ASL
        ASL
        ASL
        TAX
        LDA HGR_ROW_LO+7,X              ; the row's last scanline
        ADC MON_WNDLFT
        STA ZP_TXT_PTR
        LDA HGR_ROW_HI+7,X
        EOR ZP_PAGE_XOR
        STA ZP_TXT_PTR+1
        LDY MON_CH
        BEQ .rts
.scan   DEY
        LDA (ZP_TXT_PTR),Y
        ASL                             ; ignore the palette bit
        BNE .rts                        ; ink: stop here
        DEC MON_CH
        BNE .scan
.rts    RTS
NO_EFFECT_MSG
        SUBROUTINE
        ; The spell-fizzle reply, and the engine's beep cluster.
        ;
        ; Behavior:
        ;   Four entries: NO_EFFECT_MSG prints the fizzle message
        ;   then beeps; BEEP_CMD plays the command beep; QUERY_MARK
        ;   appends '?' after the last text and blats; BEEP_HUH
        ;   just blats. All fall into KBD_CLEAR.
        JSR MSG_PRINT
        DC.B "}Hmmmm... no effect?",$00
BEEP_CMD
        LDA #$08                        ; the command beep
        BNE .play                       ; (always)
QUERY_MARK
        ; Append a ? right after the last text, with the blat.
        JSR CURSOR_TO_TEXT
        LDA #$3F                        ; '?'
        JSR FONT_DRAW
BEEP_HUH
        LDA #$10                        ; the error blat
.play
SFX_PLAY_FLUSH                          ; (entry: play A, then
        JSR SFX_PLAY                    ;   flush -- overlays use it)
        ; falls into KBD_CLEAR
KBD_CLEAR
        ; Flush the type-ahead and sound queues and the strobe.
        BIT KBDSTRB
        LDA #$00
        STA ZP_SFX_CNT
        STA ZP_KEY_CNT
        RTS
@ %def PRINT_SPELL CURSOR_TO_TEXT NO_EFFECT_MSG BEEP_CMD QUERY_MARK
@ %def BEEP_HUH SFX_PLAY_FLUSH KBD_CLEAR

\section{Popup frames}

[[POPUP_FRAME]] opens the engine's standard popup: save the window,
set a box in the upper screen, clear it, and draw a blue pixel
rectangle around it with the library's line primitives ---
\emph{directly on the visible page}. [[PAGE_SWAP]] flips
[[ZP_PAGE_XOR]] to the other buffer; the frame swaps, draws, and
falls through into the same swap to restore. The matching teardown
is [[POPUP_END]]/[[POPUP_CLOSE]] further down.

<<miu1 popup frame>>=
        ORG $841E
POPUP_FRAME
        SUBROUTINE
        ; Open the standard popup box, framed in blue.
        ;
        ; Behavior:
        ;   Save the window; window := rows 4-15, cols 4-35; clear
        ;   it; then draw a rectangle (pixels 18..235 x 18..109)
        ;   in color 6 on the displayed page (swap, draw, swap
        ;   back via the PAGE_SWAP fall-through).
        ;
        ; Modifies:
        ;   WIN_SAVE_BUF, window variables, ZP_PX/ZP_PY
        ; Clobbers: A, X, Y
        JSR WIN_SAVE
        LDA #$04
        STA MON_WNDTOP
        STA MON_WNDLFT
        LDA #$10
        STA MON_WNDBTM
        LDA #$20
        STA MON_WNDWDTH
        JSR CLR_WINDOW
        JSR PUTCH_NL_COL1
POPUP_BORDER                            ; (entry: redraw the border
        LDA #$06                        ;   in blue)
POPUP_BORDER_A                          ; (entry: ... in color A --
        JSR COLOR_SET                   ;   OUT flashes it white)
        JSR PAGE_SWAP                   ; draw on the visible page
        LDX #$12
        LDY #$12
        STX ZP_PX
        STY ZP_PY
        LDX #$EB
        JSR LINE_TO                     ; top edge
        LDX ZP_PX
        LDY #$6D
        JSR LINE_TO                     ; right edge
        LDX #$12
        LDY ZP_PY
        JSR LINE_TO                     ; bottom edge
        LDX ZP_PX
        LDY #$12
        JSR LINE_TO                     ; left edge, and fall through
PAGE_SWAP
        ; Toggle the draw page (ZP_PAGE_XOR ^= ZP_PAGE_TGL).
        LDA ZP_PAGE_XOR
        EOR ZP_PAGE_TGL
        STA ZP_PAGE_XOR
        RTS
@ %def POPUP_FRAME POPUP_BORDER POPUP_BORDER_A PAGE_SWAP

\section{The Ready command}

\emph{R}eady asks for a second letter --- \emph{S}pell, \emph{W}eapon
or \emph{A}rmour --- echoes the class name, and dispatches through an
address-minus-one table to a handler that runs the generic
[[MENU_PICK]] over the right item list. Any other letter lands on
index 0, prints ``nothing'', and dispatches to a bare [[RTS]].
This is where the three \emph{readied} state bytes get written, and
it nails down which is which: [[READY_SPELL]] picks from the
10-entry spell list, [[READY_WEAPON]] from the 15 weapons,
[[READY_ARMOUR]] from the 5 armours.

<<miu1 ready command>>=
        ORG $8466
READY_CMD
        SUBROUTINE
        ; The R-eady command: pick what to ready.
        ;
        ; Inputs:
        ;   A       -- the follow-up key (S, W or A)
        ;
        ; Behavior:
        ;   Match against READY_KEYS (no match = entry 0,
        ;   "nothing"); push the handler address from READY_VEC;
        ;   echo the class name; RTS-dispatch to the handler.
        ;
        ; Clobbers: A, X, Y
        PHA
        LDA #$07
        STA MON_CH
        PLA
        LDX #$03
.find   CMP READY_KEYS-1,X
        BEQ .got
        DEX
        BNE .find
.got    TXA
        ASL
        TAY
        LDA READY_VEC+1,Y
        PHA
        LDA READY_VEC,Y
        PHA
        JSR STR_NTH                     ; echo "nothing/spell/..."
        DC.W READY_CLASSES
        JSR CLR_EOL
        INC MON_CH
.none   RTS                             ; entry 0 dispatches here
READY_KEYS
        DC.B "SWA"
READY_VEC
        DC.W .none-1                    ; 0: not a class: "nothing"
        DC.W READY_S-1
        DC.W READY_W-1
        DC.W READY_A-1
READY_S ; pick a spell
        LDA READY_SPELL
        JSR MENU_PICK
        DC.B $0A                        ; 10 spells
        DC.W OWNED_SPELLS
        DC.W STR_SPELLS
        STA READY_SPELL
        RTS
READY_W ; pick a weapon
        LDA READY_WEAPON
        JSR MENU_PICK
        DC.B $0F                        ; 15 weapons
        DC.W OWNED_WEAPONS
        DC.W STR_WEAPONS
        STA READY_WEAPON
        RTS
READY_A ; pick an armour
        LDA READY_ARMOUR
        JSR MENU_PICK
        DC.B $05                        ; 5 armours
        DC.W OWNED_ARMOUR
        DC.W STR_ARMOUR
        STA READY_ARMOUR
        RTS
READY_CLASSES
        ; packed string table: last char of each has the high bit
        DC.B "nothin",$E7               ; "nothing"
        DC.B "spell",$BA                ; "spell:"
        DC.B "weapon",$BA               ; "weapon:"
        DC.B "armour",$BA               ; "armour:"
@ %def READY_CMD READY_KEYS READY_VEC READY_S READY_W READY_A
@ %def READY_CLASSES

\section{The item picker}

[[MENU_PICK]] is the engine's generic chooser, used by the Ready
handlers above (and callable from overlays): five inline argument
bytes give the item count, a pointer to the \emph{owned-counts}
array, and a pointer to the name table. It lists the owned items as
\texttt{a) Name} lines, vertically centered in the viewport and
drawn on the visible page, waits for a letter, validates it (item 0
--- ``nothing''/bare hands --- is always allowed; otherwise the item
must exist and be owned, else the old selection stands), echoes the
chosen name, and returns the new index in A and X.

The letters map to item \emph{indexes}, not display rows --- unowned
items are skipped on screen but their letters are skipped too, so
\texttt{c)} is always item 2.

<<miu1 menu pick>>=
        ORG $84DF
MENU_PICK
        SUBROUTINE
        ; Choose an item from an owned-items list.
        ;
        ; Inputs:
        ;   A       -- current selection index
        ;   inline  -- count.b, owned-array ptr.w, name-table ptr.w
        ;
        ; Behavior:
        ;   Read the inline args (via the MSG_GETC pointer, fixing
        ;   the return address); list owned items lettered by index
        ;   on the visible page; KEY_WAIT; validate the letter;
        ;   close the popup; echo and return the selection.
        ;
        ; Outputs:
        ;   A = X = the selected index (unchanged if invalid key).
        ;
        ; Modifies:
        ;   ZP_ITEM, ZP_LIST, MENU_CNT, MENU_TBL, SAVE_PAGE_TGL
        STA ZP_ITEM
        PLA
        STA MSG_PTR
        PLA
        STA MSG_PTR+1
        JSR MSG_GETC
        STA MENU_CNT
        JSR MSG_GETC
        STA ZP_LIST
        JSR MSG_GETC
        STA ZP_LIST+1
        JSR MSG_GETC
        STA MENU_TBL
        JSR MSG_GETC
        STA MENU_TBL+1
        LDA MSG_PTR+1                   ; return past the arguments
        PHA
        LDA MSG_PTR
        PHA
        JSR WIN_SAVE
        JSR WIN_VIEW
        LDX #$0E
        LDY #$00
        LDA ZP_PAGE_TGL
        STA SAVE_PAGE_TGL
        STY ZP_PAGE_TGL                 ; draw on the visible page
        JSR MSG_AT
        DC.B $0E," Ready ",$18,$00
        JSR CLR_WINDOW
        LDY MENU_CNT                    ; count the owned items
        LDX #$01
.count  LDA (ZP_LIST),Y
        BEQ .skip0
        INX
.skip0  DEY
        BNE .count
        STX ZP_ROWS
        SEC
        LDA #$14
        SBC ZP_ROWS
        LSR
        STA MON_CV                      ; center the list vertically
        LDA #$61
        STA .letter                     ; .letter <- 'a'
        LDY #$00
.item   TYA
        PHA
        LDA #$0D
        STA MON_CH
        JSR MSG_PRINT
.letter = *
        DC.B "a) ",$00                  ; (the letter is patched)
        PLA
        JSR MENU_NAME                   ; item Y's name; A = Y
        TAY
        INC MON_CV
.next   CPY MENU_CNT
        BCS .pick
        INC .letter                     ; letters track the index,
        INY                             ;   shown or not
        LDA (ZP_LIST),Y
        BNE .item                       ; owned: list it
        BEQ .next
.pick   JSR WIN_RESTORE
        LDA SAVE_PAGE_TGL
        STA ZP_PAGE_TGL
        JSR PAGE_FLIP
        JSR KEY_WAIT
        PHA
        JSR POPUP_CLOSE
        SEC
        PLA
        SBC #$41                        ; letter -> item index
        BEQ MENU_NAME                   ; item 0: always allowed
        BMI .keep
        CMP MENU_CNT
        BCC .own
        BNE .keep
.own    TAY
        LDA (ZP_LIST),Y                 ; owned?
        BNE .sel
.keep   LDY ZP_ITEM                     ; invalid: keep the old one
.sel    TYA
MENU_NAME
        ; Print item A's name, capitalized, from the patched
        ; table; preserves A (X := A).
        TAX
        PHA
        JSR STR_NTH_CAP
MENU_TBL = *
        DC.W $0000                      ; (patched: the name table)
        PLA
        RTS
MENU_CNT
        DC.B $0A                        ; item count (stale value)
@ %def MENU_PICK MENU_NAME MENU_TBL MENU_CNT

\section{The Inventory display}

The Z-tats screen: a full-viewport popup listing the player ---
name, level (experience over 1000, plus one), sex, race and class
--- then the seven 16-bit stat pairs, the coin purse, and every
owned item with its count, the readied one marked with glyph
[[$1B]]. It is the engine's biggest consumer of the two-column
layout machinery that follows it.

Two details worth noting for a port: the \emph{level} is not stored
anywhere --- it is recomputed as $\lfloor exp/1000\rfloor + 1$ from
the BCD conversion's middle byte; and the coin purse is one 16-bit
number displayed as three currencies --- pence is its ones digit,
silver its tens digit, and Gold Crowns the value over 100.

<<miu1 inventory>>=
        ORG $85A2
INVENTORY
        SUBROUTINE
        ; The Z-tats / inventory popup.
        ;
        ; Behavior:
        ;   Clear the viewport; header, name, level (exp/1000+1),
        ;   sex, race, class; then in two-column item-line format:
        ;   the seven stat pairs, the three coin denominations,
        ;   enemy vessels (space mode), and the armour, transport,
        ;   item, weapon and spell lists with readied-item markers.
        ;   Ends with POPUP_END (press Space) and a frame redraw.
        ;
        ; Modifies:
        ;   SAVE_PAGE_TGL, HILITE_IDX, ZP_ITEM, NUM_PAD, window
        ; Clobbers: A, X, Y
        JSR VIEW_CLEAR
        JSR WIN_SAVE
        JSR WIN_VIEW
        JSR WIN_SHRINK
        LDX #$0C
        LDY #$00
        STY NUM_PAD
        LDA ZP_PAGE_TGL
        STA SAVE_PAGE_TGL
        STY ZP_PAGE_TGL                 ; draw on the visible page
        JSR MSG_AT
        DC.B $0E," Inventory ",$18,"||Player: ",$00
        JSR PRINT_NAME
        JSR MSG_PRINT
        DC.B "|A level ",$00
        LDX PLR_EXP
        LDA PLR_EXP+1
        JSR BIN2BCD
        LDA ZP_BCD+1
        LSR
        LSR
        LSR
        LSR                             ; the thousands digit
        CLC
        ADC #$01
        JSR PRINT_NUM8                  ; level = exp/1000 + 1
        INC MON_CH
        LDA PLR_SEX
        BEQ .male
        JSR MSG_PRINT
        DC.B "fe",$00
.male   JSR MSG_PRINT
        DC.B "male ",$00
        LDX PLR_RACE
        JSR STR_NTH
        DC.W STR_RACES
        INC MON_CH
        LDX PLR_CLASS
        JSR STR_NTH
        DC.W STR_CLASSES
        JSR ITEMWIN_SET
        DEC MON_CV
        ; --- the seven stat pairs (hits + six attributes) ---
        LDX #$00
        STX HILITE_IDX                  ; no marker on stats
.stat   STX ZP_ITEM
        TXA
        ASL
        TAY
        LDX PLR_HITS,Y                  ; 16-bit pair Y/2
        LDA PLR_HITS+1,Y
        BNE .show
        CPX #$00
        BEQ .zstat                      ; zero: leave it out
.show   JSR ITEM_LINE
        DC.W STR_STATS
.zstat  LDX ZP_ITEM
        INX
        CPX #$07
        BCC .stat
        ; --- the coin purse, in three denominations ---
        LDX PLR_COIN
        LDA PLR_COIN+1
        JSR BIN2BCD
        LDA ZP_BCD
        AND #$0F                        ; the ones digit
        BEQ .silver
        JSR COL_ADVANCE
        JSR MSG_PRINT
        DC.B "Copper pence....",$00
        LDA ZP_BCD
        JSR PRINT_DIGIT
.silver LDA ZP_BCD
        LSR
        LSR
        LSR
        LSR                             ; the tens digit
        BEQ .gold
        PHA
        JSR COL_ADVANCE
        JSR MSG_PRINT
        DC.B "Silver pieces...",$00
        PLA
        JSR PRINT_DIGIT
.gold   LDA ZP_BCD+1                    ; the value over 100
        BEQ .vessel
        JSR COL_ADVANCE
        JSR MSG_PRINT
        DC.B "Gold Crowns....",$00
        LDA ZP_BCD+1
        CMP #$10
        BCS .gold2
        LDA #$2E                        ; one digit: pad with a dot
        JSR CHAR_OUT
        LDA ZP_BCD+1
        JSR PRINT_DIGIT
        JMP .vessel
.gtext  DC.B "Enemy vessel",$F3         ; one-entry table: "vessels"
.gold2  JSR PRINT_HEX                   ; two BCD digits
.vessel LDA PLR_VESSELS
        BEQ .armour
        LDX #$00
        STX ZP_ITEM
        JSR ITEM_LINE_A
        DC.W .gtext
        ; --- the item lists ---
.armour LDA READY_ARMOUR
        STA HILITE_IDX
        LDX #$01
.arm    STX ZP_ITEM
        LDA OWNED_ARMOUR,X
        BEQ .arm1
        JSR ITEM_LINE_A
        DC.W STR_ARMOUR
.arm1   LDX ZP_ITEM
        INX
        CPX #$06
        BCC .arm
        LDA READY_TRANSPORT
        STA HILITE_IDX
        LDX #$01
.veh    STX ZP_ITEM
        LDA OWNED_TRANSPORT,X
        BEQ .veh1
        JSR ITEM_LINE_A
        DC.W STR_TRANSPORT
.veh1   LDX ZP_ITEM
        INX
        CPX #$0B
        BCC .veh
        LDX #$00
        STX HILITE_IDX
.itm    STX ZP_ITEM
        LDA OWNED_GEMS,X
        BEQ .itm1
        JSR ITEM_LINE_A
        DC.W STR_GEMS
.itm1   LDX ZP_ITEM
        INX
        CPX #$04
        BCC .itm
        LDA READY_WEAPON
        STA HILITE_IDX
        LDX #$01
.wpn    STX ZP_ITEM
        LDA OWNED_WEAPONS,X
        BEQ .wpn1
        JSR ITEM_LINE_A
        DC.W STR_WEAPONS
.wpn1   LDX ZP_ITEM
        INX
        CPX #$10
        BCC .wpn
        LDA READY_SPELL
        STA HILITE_IDX
        LDX #$01
.spl    STX ZP_ITEM
        LDA OWNED_SPELLS,X
        BEQ .spl1
        JSR ITEM_LINE_A
        DC.W STR_SPELLS
.spl1   LDX ZP_ITEM
        INX
        CPX #$0B
        BCC .spl
        JSR POPUP_END                   ; wait for Space
POPUP_CLOSE
        ; Tear down any popup: redraw the frame, restore the window.
        JSR DRAW_BORDERS
        JMP WIN_RESTORE
@ %def INVENTORY POPUP_CLOSE

\section{Two-column item lines}

The layout engine under the inventory (and the shops in the
overlays). [[COL_ADVANCE]] moves to the next row of an 18-column
cell; at row 18 it starts a second column, and were a third needed
it pauses with \emph{more} and resets the item window
([[ITEMWIN_SET]], rows 5--18). [[ITEM_LINE]] prints one
\texttt{Name......value} line: nine leader dots from column 3, the
value with \emph{dot-padded} leading zeros, then back to column 0
to print the name --- which simply overwrites the leftmost dots.
The name table is the caller's inline argument: [[ITEM_LINE]] ends
with a [[JMP]] to [[STR_NTH_CAP]], which finds the caller's return
address (and so the inline table pointer) on the stack. Glyph
[[$1B]] marks the line whose index [[ZP_ITEM]] equals
[[HILITE_IDX]] --- the readied item.

<<miu1 column layout>>=
        ORG $8772
COL_ADVANCE
        SUBROUTINE
        ; Advance to the next item-line cell.
        ;
        ; Behavior:
        ;   Column 0 of the next row; past row 17, restart at the
        ;   window top one 18-column cell to the right; past
        ;   column 38, pause with "more" and reset the item window.
        ;
        ; Modifies:
        ;   MON_CH, MON_CV, MON_WNDLFT, MON_WNDWDTH
        LDX #$00
        STX MON_CH
        LDY MON_CV
        INY
        CPY #$12
        BCC .store
        LDY MON_WNDTOP                  ; next column
        LDA #$12
        STA MON_WNDWDTH
        ADC MON_WNDLFT
        CMP #$26
        BCS .more
        STA MON_WNDLFT
.store  STY MON_CV
        RTS
.more   LDX #$0D                        ; out of room: page break
        LDY #$12
        JSR MSG_AT
        DC.B "more",$00
        JSR POPUP_END
        LDA #$00
        STA ZP_PAGE_TGL                 ; stay on the visible page
        INC MON_CH
        JSR WIN_SAVE
ITEMWIN_SET
        ; Window := the item area (rows 5-18, cols 2-37), cleared.
        LDA #$05
        STA MON_WNDTOP
        LSR
        STA MON_WNDLFT
        LDA #$24
        STA MON_WNDWDTH
        LDA #$13
        STA MON_WNDBTM
        JMP CLR_WINDOW
ITEM_LINE_A
        SUBROUTINE
        ; Print one "Name......value" line; the name table is the
        ; CALLER's inline word argument (consumed by STR_NTH_CAP).
        ;
        ; Inputs:
        ;   A (ITEM_LINE_A: 8-bit) or X/A lo/hi (ITEM_LINE)
        ;   ZP_ITEM -- item index (name table entry, marker check)
        ;   HILITE_IDX -- index to mark with glyph $1B, or 0
        ;
        ; Behavior:
        ;   COL_ADVANCE; nine leader dots from column 3; the value
        ;   dot-padded; then from column 0 the marker (if readied)
        ;   and the capitalized name over the leftmost dots.
        ;
        ; Modifies:
        ;   NUM_PAD ('.')
        TAX
        LDA #$00
ITEM_LINE
        PHA                             ; value hi
        TXA
        PHA                             ; value lo
        JSR COL_ADVANCE
        LDA #$03
        STA MON_CH
        LDX #$09
        LDA #$2E
        STA NUM_PAD                     ; pad zeros with dots too
        JSR CHAR_REPEAT                 ; nine leader dots
        PLA
        TAX
        PLA
        JSR PRINT_NUM16
        JSR CR
        LDX ZP_ITEM
        LDA HILITE_IDX
        BEQ .name
        CPX HILITE_IDX
        BNE .name
        LDA #$1B                        ; the "readied" marker glyph
        JSR CHAR_OUT
.name   JMP STR_NTH_CAP                 ; inline arg: the caller's
                                        ;   name-table pointer
@ %def COL_ADVANCE ITEMWIN_SET ITEM_LINE_A ITEM_LINE

\section{Closing a popup}

[[POPUP_END]] restores double-buffering, page-flips, copies the
result to the back buffer, restores the window, and falls into
[[PRESS_SPACE]] --- the \emph{Press Space to continue:} prompt that
also accepts Return and Escape.

<<miu1 popup end>>=
        ORG $87EC
POPUP_END
        SUBROUTINE
        ; Close a visible-page popup and wait for acknowledgement.
        ;
        ; Behavior:
        ;   Restore ZP_PAGE_TGL from SAVE_PAGE_TGL; PAGE_FLIP;
        ;   PAGE_COPY (so both buffers match); restore the window;
        ;   fall into PRESS_SPACE.
        LDA SAVE_PAGE_TGL
        STA ZP_PAGE_TGL
        JSR PAGE_FLIP
        JSR PAGE_COPY
        JSR WIN_RESTORE
PRESS_SPACE
        ; Prompt and wait for Space (or Return / Escape).
        JSR MSG_PRINT
        DC.B "}Press Space to continue: ",$00
        JSR KBD_CLEAR
.key    JSR KEY_WAIT
        CMP #$0D
        BEQ .ok
        CMP #$1B
        BEQ .ok
        CMP #$20
        BNE .key
.ok     JSR CLR_ROW
        INC MON_CH
        DEC MON_CV
        JSR KBD_CLEAR
        JMP WIN_SAVE
@ %def POPUP_END PRESS_SPACE

\section{Name and sound toggles}

<<miu1 print name>>=
        ORG $8837
PRINT_NAME
        SUBROUTINE
        ; Print the player's name.
        ;
        ; Behavior:
        ;   Characters from PLR_NAME through CHAR_OUT until the
        ;   zero terminator.
        LDX #$00
.next   LDA PLR_NAME,X
        BEQ .done
        JSR CHAR_OUT
        INX
        BNE .next
.done   RTS
@ %def PRINT_NAME

The two sound commands toggle the library's flags and mirror the
new values into the player state block ([[PLR_SOUND]]/[[PLR_SFX]],
so they persist in the save file), then echo \emph{on} or
\emph{off}.

<<miu1 sound toggles>>=
        ORG $8845
SOUND_TOGGLE
        SUBROUTINE
        ; Toggle master sound; echo " on"/" off".
        ;
        ; Behavior:
        ;   Invert SOUND_ON through SOUND_SET (which also sets the
        ;   IIgs speed policy); mirror into PLR_SOUND.
        LDA SOUND_ON
        EOR #$FF
        JSR SOUND_SET
        STA PLR_SOUND
        BNE .on
.off    JSR MSG_PRINT
        DC.B " off",$00
        RTS
SFX_TOGGLE
        ; Toggle sound effects; echo " on"/" off".
        LDA SFX_ON
        EOR #$FF
        STA SFX_ON
        STA PLR_SFX
        BEQ .off
.on     JSR MSG_PRINT
        DC.B " on",$00
        RTS
@ %def SOUND_TOGGLE SFX_TOGGLE

\section{Death}

\emph{<name>, thou art dead.} The stats are zeroed and repainted,
the viewport cleared, and a 10-byte-wide, 94-scanline image ---
stored at the very start of the file, at [[DEATH_IMG]] --- is
blitted to the middle of the screen, drawn on the visible page.
Bytes with the high bit set overwrite; others merge with [[ORA]].
The death knell (effect 2) plays twice.

<<miu1 death>>=
        ORG $8870
DEATH   SUBROUTINE
        ; Announce death, zero the vitals, draw the death image.
        ;
        ; Behavior:
        ;   Print "<name>, thou art dead."; PAGE_COPY; zero coin,
        ;   food and hits; repaint the stats panel on the visible
        ;   page; clear the viewport; blit the 10x94-byte image
        ;   from DEATH_IMG (bit 7 set: store; clear: ORA in);
        ;   queue the death knell twice; flip and flush.
        ;
        ; Modifies:
        ;   PLR_COIN, PLR_FOOD, PLR_HITS, SAVE_PAGE_TGL,
        ;   ZP_HGR_PTR, the blit pointer below
        ; Clobbers: A, X, Y
        JSR PUTCH_NL_COND
        JSR PRINT_NAME
        JSR MSG_PRINT
        DC.B ", thou art dead.",$00
        JSR PAGE_COPY
        LDA #$00
        STA PLR_COIN
        STA PLR_COIN+1
        STA PLR_FOOD
        STA PLR_FOOD+1
        STA PLR_HITS
        STA PLR_HITS+1
        LDY ZP_PAGE_TGL
        STY SAVE_PAGE_TGL
        STA ZP_PAGE_TGL                 ; single-page mode
        JSR STATS_VALUES
        JSR VIEW_CLEAR
        LDA #$02                        ; image source := one byte
        STA .imgl                       ;   before DEATH_IMG
        LDA #$70                        ;   (pre-incremented below)
        STA .imgh
        LDX #$20                        ; scanlines $20..$7D
.row    LDA HGR_ROW_LO,X
        STA ZP_HGR_PTR
        LDA HGR_ROW_HI,X
        EOR ZP_PAGE_XOR
        STA ZP_HGR_PTR+1
        LDY #$0F                        ; screen bytes 15..24
.col    INC .imgl
        BNE .get
        INC .imgh
.imgl = *+1
.imgh = *+2
.get    LDA DEATH_IMG
        BPL .mix
        ORA (ZP_HGR_PTR),Y
.mix    STA (ZP_HGR_PTR),Y
        INY
        CPY #$19
        BCC .col
        INX
        CPX #$7E
        BCC .row
        LDA #$02                        ; the death knell, twice
        JSR SFX_QUEUE
        LDA #$02
        JSR SFX_QUEUE
        LDA SAVE_PAGE_TGL
        STA ZP_PAGE_TGL
        JSR PAGE_FLIP
        JMP KBD_CLEAR
@ %def DEATH

\section{Loading a location: respawn and the overlay switch}

[[GAME_LOAD]] is how the game changes mode. The current location's
overlay name lives at [[LOC_NAME]], the head of a table of all
seven overlay names at fixed 4-byte offsets (\texttt{GEN OUT DNG
TWN CAS SPA TM}). A caller jumps here --- the stack is reset, there
is no return --- with A = the table offset of the destination: the
name is copied down into the current-location slot, parsed, loaded
through the RAM-disk cache (retrying through [[DISK_PROMPT]] ---
\emph{Put in the Ultima disk} --- on errors), the screen furniture
is redrawn, and control jumps to [[OVERLAY_ENTRY]] --- where the
file just landed. A = 0 (or any offset past the table) skips all
that and loads \texttt{GEN}, the character generator: the new-game
path. [[RESPAWN]] is death's continuation: A = 4 is the
\texttt{OUT} entry, so the slain player wakes outdoors.
[[EXIT_TO_OUT]] is the same path minus the dying --- it is how a
dungeon climb-out (see [[KLIMB_CMD]]) returns to the overworld.

<<miu1 respawn>>=
        ORG $88F8
RESPAWN SUBROUTINE
        ; Death, then resurrection outdoors.
        ;
        ; Behavior:
        ;   DEATH, then GAME_LOAD with A = 4 -- the "OUT" entry of
        ;   the location-name table.
        JSR DEATH
EXIT_TO_OUT
        ; the no-death exit: leaving a dungeon (or any mode
        ; that returns to the overworld) re-enters here
        LDA #$04
GAME_LOAD
        ; Switch to the overlay whose name is at LOC_NAME+A.
        ; No return: the stack is reset.
        LDX #$FF
        TXS
        CMP #$19
        BCS .gen                        ; bad offset: start over
        TAX
        BNE .switch
.gen    JSR MLIB_BLOAD                  ; new game: the character
        DC.B "GEN",$00                  ;   generator overlay
        BCS .gen
        JMP OVERLAY_ENTRY
.switch LDY #$00                        ; make it current: copy the
.copy   LDA LOC_NAME,X                  ;   name down to LOC_NAME
        STA LOC_NAME,Y
        INX
        INY
        ASL
        BNE .copy                       ; stop on $00 / high-bit char
.load   JSR KBD_CLEAR
        JSR MLIB_PARSE_PATH_P
        DC.W LOC_NAME
        JSR FILE_LOAD                   ; lands at OVERLAY_ENTRY
        JSR DISK_PROMPT                 ; C set: prompted, retry
        BCS .load
        JSR PAGE1_LOCK
        JSR STATS_DRAW
        JSR DRAW_BORDERS
        JSR WIN_RESTORE
        JMP OVERLAY_ENTRY
@ %def RESPAWN EXIT_TO_OUT GAME_LOAD

\section{Quit, and the bootstrap at the overlay address}

A matched pair built around a lovely trick. At startup,
[[OVERLAY_ENTRY]] saves ProDOS's reset vector \emph{into the
operand of [[QUIT]]'s final [[JMP]]}, then points the reset vector
at [[QUIT]]. From then on, pressing Reset --- or the Quit command
--- shuts the library down, puts the saved vector back, and leaves
through it. Until it is patched, the operand reads [[$FF59]], the
monitor's cold entry, so a \texttt{QUIT} before startup still lands
somewhere sane.

<<miu1 quit>>=
        ORG $893F
QUIT    SUBROUTINE
        ; Leave the game: restore the reset vector and exit
        ; through it.
        ;
        ; Behavior:
        ;   LIB_SHUTDOWN (text mode, mouse off, IIgs speed); put
        ;   the saved ProDOS reset vector back at RESET_VEC (with
        ;   the EOR #$A5 validation byte); jump through QUIT_VEC.
        JSR LIB_SHUTDOWN
        LDA QUIT_VEC
        STA RESET_VEC
        LDA QUIT_VEC+1
        STA RESET_VEC+1
        EOR #$A5
        STA RESET_VEC+2
QUIT_VEC = *+1
        JMP MON_RESET                   ; (patched: ProDOS's vector)
@ %def QUIT QUIT_VEC

And the bootstrap itself. This code sits \emph{at} [[OVERLAY_ENTRY]]
--- the address every mode overlay loads at --- so it runs exactly
once: the moment \texttt{MI.U1} starts. It hooks Reset, loads
\texttt{STUPH}, zeroes the undisplayed holes of hi-res page 2,
initializes the machine layer, sets up double-buffering, restores
the saved sound preference, and tail-calls [[GAME_LOAD]] with A = 0
--- which loads the \texttt{GEN} overlay \emph{on top of this very
code} and jumps back to [[OVERLAY_ENTRY]], now the entry point of
the character generator.

<<miu1 bootstrap>>=
        ORG $8956
OVERLAY_ENTRY
        SUBROUTINE
        ; One-shot startup code at the overlay load address.
        ;
        ; Behavior:
        ;   Hook Reset through QUIT (saving ProDOS's vector in
        ;   QUIT's JMP); load STUPH; clear hi-res page 2's hole
        ;   bytes; LIB_INIT; enable double-buffering (draw page 2
        ;   first); restore the saved sound flag; GAME_LOAD(0) --
        ;   GEN replaces this code and is entered at this address.
        SEI
        LDX #$FF
        TXS
        LDA RESET_VEC
        STA QUIT_VEC
        LDA RESET_VEC+1
        STA QUIT_VEC+1
        LDA #<QUIT
        STA RESET_VEC
        LDA #>QUIT
        STA RESET_VEC+1
        EOR #$A5
        STA RESET_VEC+2                 ; Reset now quits cleanly
.stuph  JSR MLIB_BLOAD
        DC.B "STUPH",$00
        BCS .stuph
        LDA #$00
        LDX #$40                        ; hi-res page 2: zero the 8
.page   STX .h1                         ;   undisplayed bytes of
        STX .h2                         ;   each 128-byte half-page
        LDY #$78
.h1 = *+2
.hole   STA HGR2,Y
.h2 = *+2
        STA HGR2+$80,Y
        INY
        BPL .hole
        INX
        CPX #$60
        BCC .page
        JSR WIN_FULL
        JSR MON_HOME
        JSR LIB_INIT
        LDA #$60
        STA ZP_PAGE_XOR                 ; draw on page 2 first,
        STA ZP_PAGE_TGL                 ;   double-buffered
        JSR PAGE_FLIP
        JSR PAGE1_LOCK
        BIT TXTPAGE2
        LDA SOUND_ON
        JSR SOUND_SET
        LDA #$00                        ; new game: load GEN here
        JMP GAME_LOAD
@ %def OVERLAY_ENTRY

