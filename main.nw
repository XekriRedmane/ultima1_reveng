TXTPAGE1        EQU $C054       ; display page 1
TXTPAGE2        EQU $C055       ; display page 2
HGR2            EQU $4000       ; hi-res page 2
MLIB_BLOAD      EQU $B703       ; file library: BLOAD, inline path
MLIB_PARSE_PATH_P EQU $B736     ; file library: parse path pointer
ZP_PX           EQU $06         ; STUPH: pixel column (PLOT/LINE)
ZP_PY           EQU $07         ; STUPH: pixel row
ZP_HGR_PTR      EQU $26         ; STUPH: screen pointer
ZP_PAGE_TGL     EQU $80         ; STUPH: page-flip toggle mask
; --- STUPH zero page and tables shared by the engine ---
ZP_TXT_PTR      EQU $28         ; scanline pointer (CURSOR_TO_TEXT)
ZP_BCD          EQU $62         ; BIN2BCD: 6-digit BCD result (3 bytes)
ZP_BIN          EQU $65         ; BIN2BCD: 16-bit input (2 bytes)
ZP_RND_TMP      EQU $69         ; RND_MOD: limit, then result
ZP_SFX_CNT      EQU $7D         ; STUPH: pending effect count
